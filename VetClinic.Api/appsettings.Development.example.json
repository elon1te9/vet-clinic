{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=vetclinicdb_db;Username=postgres;Password=your_local_postgres_password"
  },
  "Jwt": {
    "Issuer": "VetClinic.Api",
    "Audience": "VetClinic.Client",
    "Key": "replace_with_a_long_random_local_development_key",
    "ExpiresMinutes": 120
  },
  "SeedAdmin": {
    "Email": "admin@vetclinic.local",
    "Password": "replace_with_local_admin_password",
    "FullName": "Clinic Administrator"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
