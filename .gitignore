# =========================
# VetClinic .gitignore
# =========================

# -------------------------
# Local drafts / private notes
# -------------------------
PROJECT_SPEC.md
PROJECT_SPEC.txt
README.txt
reference/

# -------------------------
# IDE / editors
# -------------------------
.vs/
.idea/
.vscode/
*.user
*.rsuser
*.suo
*.userosscache
*.sln.docstates
*.sln.iml
*.VC.db
*.VC.VC.opendb

# -------------------------
# .NET build artifacts
# -------------------------
[Bb]in/
[Oo]bj/
[Dd]ebug/
[Rr]elease/
x64/
x86/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
artifacts/
TestResults/

# -------------------------
# NuGet
# -------------------------
*.nupkg
*.snupkg
.nuget/
packages/
project.lock.json
project.assets.json

# -------------------------
# ASP.NET Core local config / secrets
# -------------------------
appsettings.Development.json
appsettings.Local.json
appsettings.*.local.json
secrets.json
.env
.env.*
*.env

# Keep base appsettings.json as a safe example only.
# Do not commit real passwords, tokens or private connection strings.

# -------------------------
# Frontend / Blazor generated files
# -------------------------
node_modules/
dist/
build/
wwwroot/lib/
wwwroot/_framework/
*.map

# -------------------------
# Logs
# -------------------------
*.log
logs/
Logs/

# -------------------------
# Database files
# -------------------------
*.db
*.sqlite
*.sqlite3
*.mdf
*.ldf

# -------------------------
# Temporary files
# -------------------------
*.tmp
*.temp
*.bak
*.swp
*.swo
~$*

# -------------------------
# OS files
# -------------------------
.DS_Store
Thumbs.db
desktop.ini
