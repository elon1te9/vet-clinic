@inject VetClinic.Client.Services.LocalStorageService LocalStorageService

<div class="nav-header">
    <a class="brand" href="">
        <span class="brand-mark">VC</span>
        <span>
            <strong>VetClinic</strong>
            <small>Клиника</small>
        </span>
    </a>
    <button title="Меню навигации" class="nav-toggle" @onclick="ToggleNavMenu">
        ☰
    </button>
</div>

<div class="@NavMenuCssClass nav-scrollable">
    <nav>
        @if (!isAuthorized)
        {
            <div class="nav-section">Старт</div>
            <NavItem Href="" Text="Главная" Match="NavLinkMatch.All" />
            <NavItem Href="login" Text="Вход" />
            <NavItem Href="register" Text="Регистрация" />
        }
        else if (role == "Admin")
        {
            <div class="nav-section">Управление</div>
            <NavItem Href="admin/dashboard" Text="Админ-панель" />
            <NavItem Href="users" Text="Пользователи" />
            <NavItem Href="owners" Text="Владельцы" />
            <NavItem Href="pets" Text="Питомцы" />
            <NavItem Href="appointments" Text="Расписание" />
            <NavItem Href="services" Text="Услуги" />

            <div class="nav-section">Клиника</div>
            <NavItem Href="inventory" Text="Склад" />
            <NavItem Href="inventory/transactions" Text="Операции склада" />
            <NavItem Href="surgeries" Text="Операции" />
            <NavItem Href="hospitalizations" Text="Стационар" />
            <NavItem Href="invoices" Text="Счета" />
            <NavItem Href="reports" Text="Отчёты" />
            <NavItem Href="notifications" Text="Уведомления" />
        }
        else if (role == "Veterinarian")
        {
            <div class="nav-section">Работа врача</div>
            <NavItem Href="appointments/my" Text="Мои записи" />
            <NavItem Href="pets" Text="Питомцы" />
            <NavItem Href="medical-records" Text="Медицинские карты" />
            <NavItem Href="vaccinations" Text="Вакцинации" />
            <NavItem Href="vaccinations/calendar" Text="Календарь вакцинаций" />
            <NavItem Href="surgeries" Text="Операции" />
            <NavItem Href="hospitalizations" Text="Стационар" />
            <NavItem Href="inventory" Text="Склад" />
            <NavItem Href="notifications" Text="Уведомления" />
        }
        else if (role == "Owner")
        {
            <div class="nav-section">Мой кабинет</div>
            <NavItem Href="pets" Text="Мои питомцы" />
            <NavItem Href="appointments/create" Text="Записаться на приём" />
            <NavItem Href="appointments/my" Text="Мои записи" />
            <NavItem Href="medical-records" Text="Медицинские карты" />
            <NavItem Href="vaccinations" Text="Вакцинации" />
            <NavItem Href="vaccinations/calendar" Text="Календарь вакцинаций" />
            <NavItem Href="invoices" Text="Счета" />
            <NavItem Href="notifications" Text="Уведомления" />
        }
        else if (role == "Assistant")
        {
            <div class="nav-section">Работа ассистента</div>
            <NavItem Href="appointments" Text="Расписание" />
            <NavItem Href="inventory" Text="Склад" />
            <NavItem Href="inventory/transactions" Text="Операции склада" />
            <NavItem Href="hospitalizations" Text="Стационар" />
            <NavItem Href="hospitalizations" Text="Уход" />
            <NavItem Href="notifications" Text="Уведомления" />
        }
    </nav>
</div>

@code {
    private bool collapseNavMenu = true;
    private bool isAuthorized;
    private string role = string.Empty;

    private string? NavMenuCssClass => collapseNavMenu ? "collapse" : null;

    protected override async Task OnInitializedAsync()
    {
        var token = await LocalStorageService.GetItemAsync("token");
        isAuthorized = !string.IsNullOrWhiteSpace(token);
        role = await LocalStorageService.GetItemAsync("role") ?? string.Empty;
    }

    private void ToggleNavMenu()
    {
        collapseNavMenu = !collapseNavMenu;
    }
}
