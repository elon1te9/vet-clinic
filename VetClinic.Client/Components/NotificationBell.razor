@implements IDisposable
@inject VetClinic.Client.Services.NotificationApiService NotificationApiService
@inject VetClinic.Client.Services.SignalRNotificationService SignalRNotificationService
@inject VetClinic.Client.Services.LocalStorageService LocalStorageService
@inject NavigationManager Navigation

<a class="notification-bell" href="notifications" title="Уведомления">
    <span>Уведомления</span>
    <strong>@unreadCount</strong>
</a>

@code {
    private int unreadCount;

    protected override async Task OnInitializedAsync()
    {
        var token = await LocalStorageService.GetItemAsync("token");
        if (string.IsNullOrWhiteSpace(token))
        {
            unreadCount = 0;
            return;
        }

        NotificationApiService.NotificationsChanged += OnNotificationsChanged;
        SignalRNotificationService.NotificationReceived += OnNotificationReceived;
        Navigation.LocationChanged += OnLocationChanged;

        await RefreshUnreadCountAsync();

        await SignalRNotificationService.StartAsync();
    }

    private async Task RefreshUnreadCountAsync()
    {
        var notifications = await NotificationApiService.GetMyAsync();
        unreadCount = notifications.Count(n => !n.IsRead);
    }

    private void OnNotificationsChanged()
    {
        _ = InvokeAsync(async () =>
        {
            await RefreshUnreadCountAsync();
            StateHasChanged();
        });
    }

    private void OnNotificationReceived(VetClinic.Shared.Responses.NotificationResponse notification)
    {
        _ = InvokeAsync(async () =>
        {
            await RefreshUnreadCountAsync();
            StateHasChanged();
        });
    }

    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs args)
    {
        OnNotificationsChanged();
    }

    public void Dispose()
    {
        NotificationApiService.NotificationsChanged -= OnNotificationsChanged;
        SignalRNotificationService.NotificationReceived -= OnNotificationReceived;
        Navigation.LocationChanged -= OnLocationChanged;
    }
}
