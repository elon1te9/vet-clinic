<span class="@CssClass">@TextValue</span>

@code {
    [Parameter]
    public object? Status { get; set; }

    [Parameter]
    public string Text { get; set; } = string.Empty;

    private string TextValue => string.IsNullOrWhiteSpace(Text) ? UiText.Status(Status) : Text;

    private string CssClass
    {
        get
        {
            return UiText.StatusTone(Status, Text) switch
            {
                "success" => "status-badge status-success",
                "danger" => "status-badge status-danger",
                "warning" => "status-badge status-warning",
                _ => "status-badge"
            };
        }
    }
}
