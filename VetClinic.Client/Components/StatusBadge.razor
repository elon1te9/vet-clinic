<span class="@CssClass">@TextValue</span>

@code {
    [Parameter]
    public object? Status { get; set; }

    [Parameter]
    public string Text { get; set; } = string.Empty;

    private string TextValue => string.IsNullOrWhiteSpace(Text)
        ? Status?.ToString() ?? string.Empty
        : Text;

    private string CssClass
    {
        get
        {
            var lower = TextValue.ToLowerInvariant();

            if (lower.Contains("paid") || lower.Contains("completed") || lower.Contains("active") || lower.Contains("confirmed"))
            {
                return "status-badge status-success";
            }

            if (lower.Contains("cancelled") || lower.Contains("overdue") || lower.Contains("critical"))
            {
                return "status-badge status-danger";
            }

            if (lower.Contains("planned") || lower.Contains("scheduled") || lower.Contains("unpaid") || lower.Contains("pending"))
            {
                return "status-badge status-warning";
            }

            return "status-badge";
        }
    }
}
