<div class="empty-state">
    <strong>@Title</strong>
    @if (!string.IsNullOrWhiteSpace(Message))
    {
        <p>@Message</p>
    }
</div>

@code {
    [Parameter]
    public string Title { get; set; } = "Информация пока не добавлена";

    [Parameter]
    public string Message { get; set; } = "Когда данные появятся, они будут отображаться в этом разделе.";
}
