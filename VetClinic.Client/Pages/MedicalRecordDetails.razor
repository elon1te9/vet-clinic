@page "/medical-records/{Id:int}"
@inject VetClinic.Client.Services.MedicalRecordApiService MedicalRecordApiService

<PageTitle>Медицинская запись</PageTitle>

<PageHeader Title="Медицинская запись" Description="Подробности осмотра, диагноз, лечение и рекомендации." />

<section class="section-card">
@if (record is null)
{
    <EmptyState Title="Медицинская запись не найдена" Message="@message" />
}
else
{
    <div class="details-grid">
        <div class="details-item">
            <span>Дата визита</span>
            <strong>@UiText.Date(record.VisitDate, withTime: false)</strong>
        </div>
        <div class="details-item">
            <span>Питомец</span>
            <strong>@UiText.Value(record.PetName)</strong>
        </div>
        <div class="details-item">
            <span>Владелец</span>
            <strong>@UiText.Value(record.OwnerFullName)</strong>
        </div>
        <div class="details-item">
            <span>Врач</span>
            <strong>@UiText.Value(record.VeterinarianFullName)</strong>
        </div>
        <div class="details-item">
            <span>Приём</span>
            <strong>@(record.AppointmentId?.ToString() ?? UiText.Empty)</strong>
        </div>
        <div class="details-item">
            <span>Температура</span>
            <strong>@(record.Temperature.HasValue ? $"{record.Temperature:0.0} °C" : UiText.Empty)</strong>
        </div>
        <div class="details-item">
            <span>Вес</span>
            <strong>@(record.Weight.HasValue ? $"{record.Weight:0.##} кг" : UiText.Empty)</strong>
        </div>
        <div class="details-item details-item-full">
            <span>Жалобы</span>
            <p>@UiText.Value(record.Complaints)</p>
        </div>
        <div class="details-item details-item-full">
            <span>Диагноз</span>
            <p>@UiText.Value(record.Diagnosis)</p>
        </div>
        <div class="details-item details-item-full">
            <span>Лечение и назначения</span>
            <p>@UiText.Value(record.Treatment)</p>
        </div>
        <div class="details-item details-item-full">
            <span>Рекомендации</span>
            <p>@UiText.Value(record.Recommendations)</p>
        </div>
    </div>
}
</section>

<div class="actions-row">
    <a class="btn btn-secondary" href="/medical-records">Назад</a>
</div>

@code {
    [Parameter] public int Id { get; set; }

    private VetClinic.Shared.Responses.MedicalRecordResponse? record;
    private string message = "Загрузка...";

    protected override async Task OnInitializedAsync()
    {
        record = await MedicalRecordApiService.GetByIdAsync(Id);
        if (record is null)
        {
            message = "Медицинская запись не найдена.";
        }
    }
}
