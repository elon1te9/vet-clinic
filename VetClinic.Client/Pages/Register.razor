@page "/register"
@inject VetClinic.Client.Services.AuthService AuthService
@inject NavigationManager Navigation

<PageTitle>Регистрация</PageTitle>

<div class="auth-page">
    <div class="auth-card">
        <h1>Регистрация</h1>
        <p class="muted">Создайте кабинет владельца питомца.</p>

        <div>
            <label>ФИО</label>
            <input @bind="fullName" placeholder="Введите ФИО" autocomplete="name" />
        </div>

        <div>
            <label>Email</label>
            <input @bind="email" placeholder="Введите email" autocomplete="email" />
        </div>

        <div>
            <label>Пароль</label>
            <input type="password" @bind="password" placeholder="Введите пароль" autocomplete="new-password" />
        </div>

        <div>
            <label>Телефон</label>
            <input @bind="phoneNumber" placeholder="Введите телефон" autocomplete="tel" />
        </div>

        <div>
            <label>Адрес</label>
            <input @bind="address" placeholder="Введите адрес" />
        </div>

        <ErrorMessage Text="@errorMessage" />

        <div class="actions-row">
            <button class="btn btn-primary" @onclick="RegisterUser" type="button">Зарегистрироваться</button>
            <a class="btn btn-secondary" href="login">Уже есть аккаунт</a>
        </div>
    </div>
</div>

@code {
    private string fullName = string.Empty;
    private string email = string.Empty;
    private string password = string.Empty;
    private string phoneNumber = string.Empty;
    private string address = string.Empty;
    private string errorMessage = string.Empty;

    private async Task RegisterUser()
    {
        if (string.IsNullOrWhiteSpace(fullName) ||
            string.IsNullOrWhiteSpace(email) ||
            string.IsNullOrWhiteSpace(password))
        {
            errorMessage = "Заполните ФИО, email и пароль.";
            return;
        }

        errorMessage = string.Empty;

        var result = await AuthService.RegisterOwnerAsync(new VetClinic.Shared.Requests.RegisterOwnerRequest
        {
            FullName = fullName,
            Email = email,
            Password = password,
            PhoneNumber = phoneNumber,
            Address = address
        });

        if (result is null)
        {
            errorMessage = "Не удалось выполнить регистрацию.";
            return;
        }

        Navigation.NavigateTo("/", true);
    }
}
