@page "/services"
@inject VetClinic.Client.Services.ClinicServiceApiService ClinicServiceApiService
@inject VetClinic.Client.Services.LocalStorageService LocalStorageService

<PageTitle>Услуги</PageTitle>

<PageHeader Title="Услуги" Description="Список услуг клиники, цены и длительность приёма." />

<section class="section-card">
@if (isAdmin)
{
    <div class="inline-create-panel service-create-panel">
        <div class="section-title-row">
            <h2>Новая услуга</h2>
        </div>

        <div class="service-create-layout">
            <div class="service-create-main">
                <div>
                    <label>Название</label>
                    <input @bind="name" placeholder="Например: вакцинация" />
                </div>

                <div>
                    <label>Описание</label>
                    <textarea @bind="description" placeholder="Кратко опишите, что входит в услугу"></textarea>
                </div>
            </div>

            <div class="service-create-side">
                <div>
                    <label>Цена, ₽</label>
                    <input type="number" step="0.01" @bind="price" placeholder="0" />
                </div>

                <div>
                    <label>Длительность, минут</label>
                    <input type="number" @bind="durationMinutes" placeholder="30" />
                </div>

                <div class="actions-row">
                    <button class="btn btn-primary" @onclick="CreateService" type="button">Создать</button>
                </div>
            </div>
        </div>
    </div>
}

<ErrorMessage Text="@message" />

@if (services.Count == 0)
{
    <EmptyState Title="Услуги пока не добавлены" Message="Создайте услуги клиники, чтобы использовать их при записи на приём и выставлении счетов." />
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>Название</th>
                <th>Цена</th>
                <th>Длительность</th>
                <th>Активна</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var service in services)
            {
                <tr>
                    <td>@UiText.Value(service.Name)</td>
                    <td>@UiText.Money(service.Price)</td>
                    <td>@service.DurationMinutes мин.</td>
                    <td><StatusBadge Status="@(service.IsActive ? "Active" : "Cancelled")" Text="@(service.IsActive ? "Активна" : "Неактивна")" /></td>
                </tr>
            }
        </tbody>
    </table>
}
</section>

@code {
    private List<VetClinic.Shared.Responses.ClinicServiceResponse> services = [];
    private bool isAdmin;
    private string name = string.Empty;
    private string description = string.Empty;
    private decimal price;
    private int durationMinutes = 30;
    private string message = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        var role = await LocalStorageService.GetItemAsync("role") ?? string.Empty;
        isAdmin = role == "Admin";
        await LoadServicesAsync();
    }

    private async Task LoadServicesAsync()
    {
        services = await ClinicServiceApiService.GetAllAsync();
    }

    private async Task CreateService()
    {
        if (string.IsNullOrWhiteSpace(name) || price < 0 || durationMinutes <= 0)
        {
            message = "Заполните название, цену и длительность услуги.";
            return;
        }

        var result = await ClinicServiceApiService.CreateAsync(new VetClinic.Shared.Requests.CreateClinicServiceRequest
        {
            Name = name,
            Description = string.IsNullOrWhiteSpace(description) ? null : description,
            Price = price,
            DurationMinutes = durationMinutes,
            IsActive = true
        });

        if (result is null)
        {
            message = "Не удалось сохранить данные. Проверьте заполнение формы.";
            return;
        }

        name = string.Empty;
        description = string.Empty;
        price = 0;
        durationMinutes = 30;
        message = "Услуга создана.";

        await LoadServicesAsync();
    }
}
