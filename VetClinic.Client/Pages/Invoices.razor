@page "/invoices"
@using VetClinic.Shared.Enums
@using VetClinic.Shared.Requests
@using VetClinic.Shared.Responses
@inject VetClinic.Client.Services.FinanceApiService FinanceApiService
@inject VetClinic.Client.Services.AppointmentApiService AppointmentApiService
@inject VetClinic.Client.Services.LocalStorageService LocalStorageService

<PageTitle>Счета</PageTitle>

<PageHeader Title="Счета" Description="Создание, просмотр и оплата счетов по приёмам." />

<ErrorMessage Text="@message" />

<section class="section-card">
@if (role == "Admin")
{
    <div class="inline-create-panel invoice-create-panel">
        <div class="section-title-row">
            <h2>Создать счёт</h2>
        </div>

        <div class="invoice-create-layout">
            <div>
                <label>Приём</label>
                <select @bind="createRequest.AppointmentId">
                    <option value="0">Выберите приём</option>
                    @foreach (var appointment in AvailableAppointments)
                    {
                        <option value="@appointment.Id">
                            #@appointment.Id - @appointment.PetName - @appointment.ServiceName - @appointment.StartAt.ToString("dd.MM.yyyy HH:mm")
                        </option>
                    }
                </select>
            </div>

            <div class="actions-row">
                <button class="btn btn-primary" type="button" @onclick="CreateInvoice">Создать</button>
            </div>
        </div>
    </div>
}

@if (invoices.Count == 0)
{
    <EmptyState Title="Счета пока не созданы" Message="Создайте счёт по завершённому приёму, чтобы зафиксировать оплату услуги." />
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>ID</th>
                <th>Приём</th>
                <th>Владелец</th>
                <th>Услуга</th>
                <th>Сумма</th>
                <th>Статус</th>
                <th>Создан</th>
                <th>Оплачен</th>
                <th class="table-actions-cell"></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var invoice in invoices)
            {
                <tr>
                    <td>@invoice.Id</td>
                    <td>@invoice.AppointmentId</td>
                    <td>@UiText.Value(invoice.OwnerFullName)</td>
                    <td>@UiText.Value(invoice.ServiceName)</td>
                    <td>@UiText.Money(invoice.Amount)</td>
                    <td><StatusBadge Status="@invoice.Status" /></td>
                    <td>@UiText.Date(invoice.CreatedAt)</td>
                    <td>@UiText.Date(invoice.PaidAt)</td>
                    <td class="table-actions-cell">
                        <a class="btn btn-secondary btn-sm" href="@($"invoices/{invoice.Id}")">Открыть</a>
                        @if (role == "Admin" && invoice.Status == InvoiceStatus.Unpaid)
                        {
                            <button class="btn btn-primary btn-sm" type="button" @onclick="() => PayInvoice(invoice.Id)">Оплатить</button>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
</section>

@code {
    private List<InvoiceResponse> invoices = [];
    private List<AppointmentResponse> appointments = [];
    private CreateInvoiceRequest createRequest = new();
    private string role = string.Empty;
    private string message = string.Empty;
    private IEnumerable<AppointmentResponse> AvailableAppointments
    {
        get
        {
            var invoiceAppointmentIds = invoices.Select(i => i.AppointmentId).ToHashSet();
            return appointments.Where(a => !invoiceAppointmentIds.Contains(a.Id));
        }
    }

    protected override async Task OnInitializedAsync()
    {
        role = await LocalStorageService.GetItemAsync("role") ?? string.Empty;

        if (role == "Admin")
        {
            appointments = await AppointmentApiService.GetAllAsync();
        }

        await LoadInvoicesAsync();
    }

    private async Task LoadInvoicesAsync()
    {
        invoices = role == "Owner"
            ? await FinanceApiService.GetMyAsync()
            : await FinanceApiService.GetAllAsync();
    }

    private async Task CreateInvoice()
    {
        if (createRequest.AppointmentId <= 0)
        {
            message = "Выберите приём.";
            return;
        }

        var result = await FinanceApiService.CreateAsync(createRequest);
        message = result is null ? "Не удалось сохранить данные. Проверьте заполнение формы." : "Счёт создан.";

        createRequest = new CreateInvoiceRequest();
        await LoadInvoicesAsync();
    }

    private async Task PayInvoice(int id)
    {
        var result = await FinanceApiService.PayAsync(id);
        message = result is null ? "Не удалось оплатить счёт. Попробуйте обновить страницу." : "Счёт оплачен.";

        await LoadInvoicesAsync();
    }
}
