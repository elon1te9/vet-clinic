@page "/users"
@inject VetClinic.Client.Services.UserApiService UserApiService
@inject VetClinic.Client.Services.LocalStorageService LocalStorageService

<PageTitle>Пользователи</PageTitle>

<PageHeader Title="Пользователи" Description="Пользователи системы и их роли." />

<ErrorMessage Text="@message" />

<section class="section-card">
@if (users.Count > 0)
{
    <table class="table">
        <thead>
            <tr>
                <th>ФИО</th>
                <th>Электронная почта</th>
                <th>Роль</th>
                <th>Активен</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var user in users)
            {
                <tr>
                    <td>@UiText.Value(user.FullName)</td>
                    <td>@UiText.Value(user.Email)</td>
                    <td>@UiText.Role(user.Role)</td>
                    <td><StatusBadge Status="@(user.IsActive ? "Active" : "Cancelled")" Text="@(user.IsActive ? "Активен" : "Неактивен")" /></td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <EmptyState Title="Пользователи не найдены" Message="Пользователи появятся здесь после регистрации или создания сотрудника." />
}
</section>

@code {
    private List<VetClinic.Shared.Responses.UserResponse> users = [];
    private string message = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        var role = await LocalStorageService.GetItemAsync("role") ?? string.Empty;
        if (role != "Admin")
        {
            message = "Недостаточно прав для выполнения действия.";
            return;
        }

        users = await UserApiService.GetUsersAsync();
        if (users.Count == 0)
        {
            message = string.Empty;
        }
    }
}
