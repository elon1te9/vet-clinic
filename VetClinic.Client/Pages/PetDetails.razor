@page "/pets/{Id:int}"
@inject VetClinic.Client.Services.PetApiService PetApiService

<PageTitle>Карточка питомца</PageTitle>

<PageHeader Title="Карточка питомца" Description="Основная информация о питомце и владельце." />

@if (pet is null)
{
    <EmptyState Title="Питомец не найден" Message="@message" />
}
else
{
    <section class="section-card details-list">
        <p><strong>Имя:</strong> @UiText.Value(pet.Name)</p>
        <p><strong>Вид:</strong> @UiText.Value(pet.Species)</p>
        <p><strong>Порода:</strong> @UiText.Value(pet.Breed)</p>
        <p><strong>Пол:</strong> @UiText.Gender(pet.Gender)</p>
        <p><strong>Дата рождения:</strong> @UiText.Date(pet.BirthDate, withTime: false)</p>
        <p><strong>Вес:</strong> @FormatWeight(pet.Weight)</p>
        <p><strong>Окрас:</strong> @UiText.Value(pet.Color)</p>
        <p><strong>Особенности здоровья:</strong> @UiText.Value(pet.HealthNotes)</p>
        <p><strong>Владелец:</strong> @UiText.Value(pet.OwnerFullName)</p>
    </section>

    <a class="btn btn-secondary" href="pets">Назад</a>
}

@code {
    [Parameter] public int Id { get; set; }

    private VetClinic.Shared.Responses.PetResponse? pet;
    private string message = "Загрузка...";

    protected override async Task OnInitializedAsync()
    {
        pet = await PetApiService.GetByIdAsync(Id);
        if (pet is null)
        {
            message = "Питомец не найден.";
        }
    }

    private static string FormatWeight(decimal? weight)
    {
        return weight.HasValue
            ? $"{weight.Value.ToString("0.00", System.Globalization.CultureInfo.GetCultureInfo("ru-RU"))} кг"
            : UiText.Empty;
    }
}
