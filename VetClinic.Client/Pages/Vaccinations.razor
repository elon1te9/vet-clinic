@page "/vaccinations"
@inject VetClinic.Client.Services.VaccinationApiService VaccinationApiService
@inject VetClinic.Client.Services.PetApiService PetApiService
@inject VetClinic.Client.Services.LocalStorageService LocalStorageService
@inject NavigationManager Navigation

<PageTitle>Вакцинации</PageTitle>

<PageHeader Title="Вакцинации" Description="История вакцинаций питомцев и план следующих дат.">
    <Actions>
        @if (role == "Veterinarian")
        {
            <button class="btn btn-primary" @onclick="OpenCreatePage" type="button">Добавить вакцинацию</button>
        }
    </Actions>
</PageHeader>

<section class="section-card vaccinations-page">
    <div class="vaccinations-toolbar">
        <div class="vaccinations-filter">
            <label>Питомец</label>
            <select @bind="selectedPetId">
                <option value="0">Все питомцы</option>
                @foreach (var pet in pets)
                {
                    <option value="@pet.Id">@pet.Name</option>
                }
            </select>
        </div>
    </div>

    <ErrorMessage Text="@message" />

    @if (FilteredVaccinations.Count == 0)
    {
        <EmptyState Title="Вакцинации пока не добавлены" Message="Когда врач добавит вакцинацию, она появится в истории питомца." />
    }
    else
    {
        <table class="table vaccinations-table">
            <thead>
                <tr>
                    <th>Питомец</th>
                    <th>Вакцина</th>
                    <th>Дата вакцинации</th>
                    <th>Следующая дата</th>
                    <th>Статус</th>
                    <th>Врач</th>
                    <th>Заметки</th>
                    @if (role == "Veterinarian")
                    {
                        <th class="table-actions-cell"></th>
                    }
                </tr>
            </thead>
            <tbody>
                @foreach (var vaccination in FilteredVaccinations)
                {
                    <tr>
                        <td>@UiText.Value(vaccination.PetName)</td>
                        <td>@UiText.Value(vaccination.Name)</td>
                        <td>@UiText.Date(vaccination.DoneAt, withTime: false)</td>
                        <td>@UiText.Date(vaccination.NextDueAt, withTime: false)</td>
                        <td><StatusBadge Status="@vaccination.Status" /></td>
                        <td>@UiText.Value(vaccination.VeterinarianFullName)</td>
                        <td>@UiText.Value(vaccination.Notes)</td>
                        @if (role == "Veterinarian")
                        {
                            <td class="table-actions-cell">
                                @if (CanEditVaccination(vaccination))
                                {
                                    <button class="btn btn-secondary btn-sm" @onclick="() => OpenEditPage(vaccination.Id)" type="button">Изменить</button>
                                }
                            </td>
                        }
                    </tr>
                }
            </tbody>
        </table>
    }
</section>

@code {
    private List<VetClinic.Shared.Responses.VaccinationResponse> vaccinations = [];
    private List<VetClinic.Shared.Responses.PetResponse> pets = [];
    private string role = string.Empty;
    private string currentUserId = string.Empty;
    private int selectedPetId;
    private string message = string.Empty;

    private List<VetClinic.Shared.Responses.VaccinationResponse> FilteredVaccinations => vaccinations
        .Where(vaccination => selectedPetId == 0 || vaccination.PetId == selectedPetId)
        .OrderBy(vaccination => SortGroup(vaccination))
        .ThenBy(vaccination => vaccination.NextDueAt ?? DateTime.MaxValue)
        .ThenByDescending(vaccination => vaccination.DoneAt)
        .ToList();

    protected override async Task OnInitializedAsync()
    {
        role = await LocalStorageService.GetItemAsync("role") ?? string.Empty;
        currentUserId = await LocalStorageService.GetItemAsync("userId") ?? string.Empty;

        pets = role is "Admin" or "Veterinarian"
            ? await PetApiService.GetAllAsync()
            : await PetApiService.GetMyAsync();

        vaccinations = role is "Admin" or "Veterinarian"
            ? await VaccinationApiService.GetAllAsync()
            : await VaccinationApiService.GetMyAsync();

        message = string.Empty;
    }

    private void OpenCreatePage()
    {
        Navigation.NavigateTo("/vaccinations/create");
    }

    private void OpenEditPage(int id)
    {
        Navigation.NavigateTo($"/vaccinations/{id}/edit");
    }

    private bool CanEditVaccination(VetClinic.Shared.Responses.VaccinationResponse vaccination)
    {
        return role == "Veterinarian" &&
               !string.IsNullOrWhiteSpace(currentUserId) &&
               vaccination.VeterinarianId == currentUserId;
    }

    private static int SortGroup(VetClinic.Shared.Responses.VaccinationResponse vaccination)
    {
        return vaccination.Status switch
        {
            VetClinic.Shared.Enums.VaccinationStatus.Planned => 0,
            VetClinic.Shared.Enums.VaccinationStatus.Cancelled => 2,
            VetClinic.Shared.Enums.VaccinationStatus.Overdue => 3,
            VetClinic.Shared.Enums.VaccinationStatus.Completed => 4,
            _ => 1
        };
    }
}
