@page "/invoices/{Id:int}"
@using VetClinic.Shared.Enums
@using VetClinic.Shared.Responses
@inject VetClinic.Client.Services.FinanceApiService FinanceApiService
@inject VetClinic.Client.Services.LocalStorageService LocalStorageService

<PageTitle>Счёт</PageTitle>

<PageHeader Title="Счёт" Description="Подробная информация по счёту." />

<ErrorMessage Text="@message" />

<section class="section-card">
@if (invoice is null)
{
    <EmptyState Title="Счёт не найден" Message="Запись не найдена. Вернитесь к списку счетов и откройте счёт заново." />
}
else
{
    <div class="details-grid">
        <div class="details-item">
            <span>ID</span>
            <strong>@invoice.Id</strong>
        </div>
        <div class="details-item">
            <span>Приём</span>
            <strong>@invoice.AppointmentId</strong>
        </div>
        <div class="details-item">
            <span>Владелец</span>
            <strong>@UiText.Value(invoice.OwnerFullName)</strong>
        </div>
        <div class="details-item">
            <span>Услуга</span>
            <strong>@UiText.Value(invoice.ServiceName)</strong>
        </div>
        <div class="details-item">
            <span>Сумма</span>
            <strong>@UiText.Money(invoice.Amount)</strong>
        </div>
        <div class="details-item">
            <span>Статус</span>
            <strong><StatusBadge Status="@invoice.Status" /></strong>
        </div>
        <div class="details-item">
            <span>Создан</span>
            <strong>@UiText.Date(invoice.CreatedAt)</strong>
        </div>
        <div class="details-item">
            <span>Оплачен</span>
            <strong>@UiText.Date(invoice.PaidAt)</strong>
        </div>
    </div>

    @if (role == "Admin" && invoice.Status == InvoiceStatus.Unpaid)
    {
        <div class="actions-row">
            <button class="btn btn-primary" type="button" @onclick="PayInvoice">Оплатить</button>
        </div>
    }
}

<div class="actions-row">
    <a class="btn btn-secondary" href="/invoices">Назад к счетам</a>
</div>
</section>

@code {
    [Parameter]
    public int Id { get; set; }

    private InvoiceResponse? invoice;
    private string role = string.Empty;
    private string message = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        role = await LocalStorageService.GetItemAsync("role") ?? string.Empty;
        invoice = await FinanceApiService.GetByIdAsync(Id);
    }

    private async Task PayInvoice()
    {
        var result = await FinanceApiService.PayAsync(Id);
        message = result is null ? "Не удалось оплатить счёт. Попробуйте обновить страницу." : "Счёт оплачен.";

        invoice = await FinanceApiService.GetByIdAsync(Id);
    }
}
