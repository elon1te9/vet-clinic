@page "/owners"
@inject VetClinic.Client.Services.UserApiService UserApiService

<PageTitle>Владельцы</PageTitle>

<PageHeader Title="Владельцы" Description="Список владельцев питомцев." />

<ErrorMessage Text="@message" />

<section class="section-card">
@if (owners.Count > 0)
{
    <table class="table">
        <thead>
            <tr>
                <th>ФИО</th>
                <th>Электронная почта</th>
                <th>Телефон</th>
                <th>Активен</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var owner in owners)
            {
                <tr>
                    <td>@UiText.Value(owner.FullName)</td>
                    <td>@UiText.Value(owner.Email)</td>
                    <td>@UiText.Value(owner.PhoneNumber)</td>
                    <td><StatusBadge Status="@(owner.IsActive ? "Active" : "Cancelled")" Text="@(owner.IsActive ? "Активен" : "Неактивен")" /></td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <EmptyState Title="Владельцы пока не добавлены" Message="После регистрации владельцев питомцев они появятся в этом списке." />
}
</section>

@code {
    private List<VetClinic.Shared.Responses.UserResponse> owners = [];
    private string message = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        owners = await UserApiService.GetOwnersAsync();

        if (owners.Count == 0)
        {
            message = string.Empty;
        }
    }
}
