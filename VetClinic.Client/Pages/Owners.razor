@page "/owners"
@inject VetClinic.Client.Services.UserApiService UserApiService

<PageTitle>Владельцы</PageTitle>

<PageHeader Title="Владельцы" Description="Список владельцев питомцев." />

<ErrorMessage Text="@message" />

<section class="section-card">
@if (owners.Count > 0)
{
    <table class="table">
        <thead>
            <tr>
                <th>ФИО</th>
                <th>Email</th>
                <th>Телефон</th>
                <th>Активен</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var owner in owners)
            {
                <tr>
                    <td>@owner.FullName</td>
                    <td>@owner.Email</td>
                    <td>@owner.PhoneNumber</td>
                    <td>@(owner.IsActive ? "Да" : "Нет")</td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <EmptyState Title="Владельцы не найдены" Message="Список владельцев пока пуст." />
}
</section>

@code {
    private List<VetClinic.Shared.Responses.UserResponse> owners = [];
    private string message = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        owners = await UserApiService.GetOwnersAsync();

        if (owners.Count == 0)
        {
            message = "Владельцы не найдены.";
        }
    }
}
