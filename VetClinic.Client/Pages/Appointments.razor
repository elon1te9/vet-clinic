@page "/appointments"
@inject VetClinic.Client.Services.AppointmentApiService AppointmentApiService
@inject VetClinic.Client.Services.LocalStorageService LocalStorageService

<PageTitle>Записи на приём</PageTitle>

<PageHeader Title="Записи на приём"
            Description="Расписание клиники и управление статусами приёмов." />

<ErrorMessage Text="@message" />

<section class="section-card">
    @if (appointments.Count == 0)
    {
        <EmptyState Title="Записей нет" Message="Список записей пока пуст." />
    }
    else
    {
        <table class="table">
            <thead>
                <tr>
                    <th>Дата</th>
                    <th>Питомец</th>
                    <th>Владелец</th>
                    <th>Врач</th>
                    <th>Услуга</th>
                    <th>Статус</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var appointment in appointments)
                {
                    <tr>
                        <td>@FormatDate(appointment.StartAt)</td>
                        <td>@appointment.PetName</td>
                        <td>@appointment.OwnerFullName</td>
                        <td>@appointment.VeterinarianFullName</td>
                        <td>@appointment.ServiceName</td>
                        <td><StatusBadge Status="@appointment.Status" /></td>
                        <td>
                            @if (canChangeStatus)
                            {
                                <button class="btn btn-primary btn-sm" @onclick="() => ChangeStatus(appointment.Id, VetClinic.Shared.Enums.AppointmentStatus.Confirmed)" type="button">Подтвердить</button>
                                <button class="btn btn-secondary btn-sm" @onclick="() => ChangeStatus(appointment.Id, VetClinic.Shared.Enums.AppointmentStatus.Completed)" type="button">Завершить</button>
                                <button class="btn btn-danger btn-sm" @onclick="() => ChangeStatus(appointment.Id, VetClinic.Shared.Enums.AppointmentStatus.Cancelled)" type="button">Отменить</button>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</section>

@code {
    private List<VetClinic.Shared.Responses.AppointmentResponse> appointments = [];
    private string role = string.Empty;
    private string message = string.Empty;

    private bool canChangeStatus => role == "Admin" || role == "Veterinarian";

    protected override async Task OnInitializedAsync()
    {
        role = await LocalStorageService.GetItemAsync("role") ?? string.Empty;
        await LoadAppointmentsAsync();
    }

    private async Task LoadAppointmentsAsync()
    {
        message = string.Empty;

        appointments = role == "Veterinarian"
            ? await AppointmentApiService.GetMyAsync()
            : await AppointmentApiService.GetAllAsync();
    }

    private async Task ChangeStatus(int id, VetClinic.Shared.Enums.AppointmentStatus status)
    {
        var result = await AppointmentApiService.UpdateStatusAsync(id, new VetClinic.Shared.Requests.UpdateAppointmentStatusRequest
        {
            Status = status
        });

        message = result is null ? "Не удалось изменить статус записи." : string.Empty;
        await LoadAppointmentsAsync();
    }

    private static string FormatDate(DateTime value)
    {
        return value.ToLocalTime().ToString("dd.MM.yyyy HH:mm");
    }
}
