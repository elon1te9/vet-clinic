@page "/hospitalizations/{Id:int}"
@inject VetClinic.Client.Services.HospitalizationApiService HospitalizationApiService
@inject VetClinic.Client.Services.LocalStorageService LocalStorageService

<PageTitle>Госпитализация</PageTitle>

<PageHeader Title="Госпитализация" Description="Детали стационара и записи ухода." />

<ErrorMessage Text="@message" />

<section class="section-card">
@if (hospitalization is null)
{
    <EmptyState Title="Госпитализация не найдена" Message="Проверьте идентификатор госпитализации." />
}
else
{
    <div class="details-grid hospitalization-summary">
        <div class="details-item">
            <span>Питомец</span>
            <strong>@UiText.Value(hospitalization.PetName)</strong>
        </div>
        <div class="details-item">
            <span>Палата</span>
            <strong>@UiText.Value(hospitalization.WardNumber)</strong>
        </div>
        <div class="details-item">
            <span>Статус</span>
            <strong><StatusBadge Status="@hospitalization.Status" /></strong>
        </div>
        <div class="details-item">
            <span>Режим кормления</span>
            <strong>@UiText.Value(hospitalization.FeedingSchedule)</strong>
        </div>
        <div class="details-item details-item-full">
            <span>Состояние</span>
            <p>@UiText.Value(hospitalization.ConditionNotes)</p>
        </div>
    </div>

    @if ((role == "Assistant" || role == "Veterinarian") && hospitalization.Status == VetClinic.Shared.Enums.HospitalizationStatus.Active)
    {
        <div class="inline-create-panel care-log-panel">
            <div class="section-title-row">
                <h2>Новая запись ухода</h2>
            </div>

            <div class="care-log-layout">
                <div class="care-log-main">
                    <div>
                        <label>Температура</label>
                        <input type="number" step="0.1" @bind="temperature" placeholder="38,5" />
                    </div>

                    <div>
                        <label>Кормление</label>
                        <input @bind="feeding" placeholder="Что и когда питомец ел" />
                    </div>

                    <div>
                        <label>Лекарства</label>
                        <input @bind="medication" placeholder="Выданные лекарства" />
                    </div>
                </div>

                <div class="care-log-notes">
                    <div>
                        <label>Состояние</label>
                        <input @bind="condition" placeholder="Состояние питомца" />
                    </div>

                    <div>
                        <label>Заметки</label>
                        <textarea @bind="notes" placeholder="Дополнительные заметки"></textarea>
                    </div>

                    <div class="actions-row">
                        <button class="btn btn-primary" @onclick="CreateCareLog" type="button">Создать</button>
                    </div>
                </div>
            </div>
        </div>
    }

    <h2>Записи ухода</h2>
    @if (careLogs.Count == 0)
    {
        <EmptyState Title="Записей ухода пока нет" Message="Добавьте запись ухода, чтобы фиксировать состояние, кормление и назначения." />
    }
    else
    {
        <table class="table">
            <thead>
                <tr>
                    <th>Дата</th>
                    <th>Сотрудник</th>
                    <th>Температура</th>
                    <th>Кормление</th>
                    <th>Лекарства</th>
                    <th>Состояние</th>
                    <th>Заметки</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var log in careLogs)
                {
                    <tr>
                        <td>@UiText.Date(log.CreatedAt)</td>
                        <td>@UiText.Value(log.StaffFullName)</td>
                        <td>@(log.Temperature.HasValue ? $"{log.Temperature:0.0} °C" : UiText.Empty)</td>
                        <td>@UiText.Value(log.Feeding)</td>
                        <td>@UiText.Value(log.Medication)</td>
                        <td>@UiText.Value(log.Condition)</td>
                        <td>@UiText.Value(log.Notes)</td>
                    </tr>
                }
            </tbody>
        </table>
    }

    <div class="actions-row">
        <a class="btn btn-secondary" href="/hospitalizations">Назад к стационару</a>
    </div>
}
</section>

@code {
    [Parameter] public int Id { get; set; }

    private VetClinic.Shared.Responses.HospitalizationResponse? hospitalization;
    private List<VetClinic.Shared.Responses.CareLogResponse> careLogs = [];
    private string role = string.Empty;
    private decimal? temperature;
    private string feeding = string.Empty;
    private string medication = string.Empty;
    private string condition = string.Empty;
    private string notes = string.Empty;
    private string message = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        role = await LocalStorageService.GetItemAsync("role") ?? string.Empty;
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        hospitalization = await HospitalizationApiService.GetByIdAsync(Id);
        careLogs = await HospitalizationApiService.GetCareLogsAsync(Id);
    }

    private async Task CreateCareLog()
    {
        var result = await HospitalizationApiService.CreateCareLogAsync(new VetClinic.Shared.Requests.CreateCareLogRequest
        {
            HospitalizationId = Id,
            Temperature = temperature,
            Feeding = string.IsNullOrWhiteSpace(feeding) ? null : feeding,
            Medication = string.IsNullOrWhiteSpace(medication) ? null : medication,
            Condition = string.IsNullOrWhiteSpace(condition) ? null : condition,
            Notes = string.IsNullOrWhiteSpace(notes) ? null : notes
        });

        if (result is null)
        {
            message = "Не удалось сохранить данные. Проверьте заполнение формы.";
            return;
        }

        temperature = null;
        feeding = string.Empty;
        medication = string.Empty;
        condition = string.Empty;
        notes = string.Empty;
        message = "Запись ухода добавлена.";

        await LoadAsync();
    }
}
