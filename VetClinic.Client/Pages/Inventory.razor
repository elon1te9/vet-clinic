@page "/inventory"
@inject VetClinic.Client.Services.InventoryApiService InventoryApiService
@inject VetClinic.Client.Services.LocalStorageService LocalStorageService

<PageTitle>Склад</PageTitle>

<PageHeader Title="Склад"
            Description="Остатки препаратов, вакцин, кормов и расходных материалов.">
    <Actions>
        @if (role == "Admin")
        {
            <a class="btn btn-primary" href="inventory/create">Создать позицию</a>
        }
    </Actions>
</PageHeader>

<ErrorMessage Text="@message" />

<section class="section-card">
    <h2>Критические остатки</h2>
    @if (lowStockItems.Count == 0)
    {
        <EmptyState Title="Критических остатков нет" Message="Все активные складские позиции выше минимального остатка." />
    }
    else
    {
        <table class="table">
            <thead>
                <tr>
                    <th>Позиция</th>
                    <th>Остаток</th>
                    <th>Минимум</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in lowStockItems)
                {
                    <tr>
                        <td>@UiText.Value(item.Name)</td>
                        <td>@UiText.Quantity(item.Quantity, item.Unit)</td>
                        <td>@UiText.Quantity(item.MinQuantity, item.Unit)</td>
                    </tr>
                }
            </tbody>
        </table>
    }
</section>

<section class="section-card">
    <h2>Истекающие сроки годности</h2>
    @if (expiringItems.Count == 0)
    {
        <EmptyState Title="Истекающих позиций нет" Message="На ближайший период просроченных или истекающих складских позиций не найдено." />
    }
    else
    {
        <table class="table">
            <thead>
                <tr>
                    <th>Позиция</th>
                    <th>Категория</th>
                    <th>Срок годности</th>
                    <th>Остаток</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in expiringItems)
                {
                    <tr>
                        <td>@UiText.Value(item.Name)</td>
                        <td>@UiText.Category(item.Category)</td>
                        <td>@UiText.Date(item.ExpirationDate, withTime: false)</td>
                        <td>@UiText.Quantity(item.Quantity, item.Unit)</td>
                    </tr>
                }
            </tbody>
        </table>
    }
</section>

<section class="section-card">
    <h2>Все позиции</h2>
    @if (items.Count == 0)
    {
        <EmptyState Title="Складские позиции пока не добавлены" Message="Создайте позицию, чтобы вести остатки, сроки годности и операции склада." />
    }
    else
    {
        <table class="table">
            <thead>
                <tr>
                    <th>Название</th>
                    <th>Категория</th>
                    <th>Остаток</th>
                    <th>Минимум</th>
                    <th>Срок годности</th>
                    <th>Цена</th>
                    <th>Активна</th>
                    <th class="table-actions-cell"></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in items)
                {
                    <tr>
                        <td>@UiText.Value(item.Name)</td>
                        <td>@UiText.Category(item.Category)</td>
                        <td>@UiText.Quantity(item.Quantity, item.Unit)</td>
                        <td>@UiText.Quantity(item.MinQuantity, item.Unit)</td>
                        <td>@UiText.Date(item.ExpirationDate, withTime: false)</td>
                        <td>@UiText.Money(item.Price)</td>
                        <td><StatusBadge Text="@(item.IsActive ? "Активна" : "Неактивна")" /></td>
                        <td class="table-actions-cell">
                            @if (role == "Admin")
                            {
                                <a class="btn btn-secondary btn-sm" href="@($"inventory/edit/{item.Id}")">Изменить</a>
                                <button class="btn btn-danger btn-sm" @onclick="() => DeleteItem(item.Id)" type="button">Удалить</button>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</section>

@code {
    private List<VetClinic.Shared.Responses.InventoryItemResponse> items = [];
    private List<VetClinic.Shared.Responses.InventoryItemResponse> lowStockItems = [];
    private List<VetClinic.Shared.Responses.InventoryItemResponse> expiringItems = [];
    private string role = string.Empty;
    private string message = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        role = await LocalStorageService.GetItemAsync("role") ?? string.Empty;
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        items = await InventoryApiService.GetAllAsync();
        lowStockItems = await InventoryApiService.GetLowStockAsync();
        expiringItems = await InventoryApiService.GetExpiringAsync();
    }

    private async Task DeleteItem(int id)
    {
        var result = await InventoryApiService.DeleteAsync(id);
        message = result ? string.Empty : "Не удалось удалить позицию.";

        await LoadAsync();
    }
}
