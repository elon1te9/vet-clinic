@page "/admin/dashboard"
@implements IDisposable
@using VetClinic.Shared.Responses
@inject VetClinic.Client.Services.AdminDashboardApiService AdminDashboardApiService
@inject VetClinic.Client.Services.SignalRNotificationService SignalRNotificationService

<PageTitle>Админ-панель</PageTitle>

<PageHeader Title="Админ-панель"
            Description="Краткая сводка по приёмам, выручке, стационару, складу и ближайшим вакцинациям." />

<ErrorMessage Text="@message" />

@if (dashboard is null && string.IsNullOrWhiteSpace(message))
{
    <Loading Text="Загрузка админ-панели..." />
}
else if (dashboard is null)
{
    <EmptyState Title="Данные не загружены" Message="Попробуйте обновить страницу или войти под администратором." />
}
else
{
    <div class="dashboard-cards">
        <DashboardCard Title="Приёмов сегодня" Value="@dashboard.AppointmentsTodayCount.ToString()" Description="Записи на текущий день" />
        <DashboardCard Title="Выручка сегодня" Value="@UiText.Money(dashboard.RevenueToday)" Description="Оплаченные счета" />
        <DashboardCard Title="Стационар" Value="@dashboard.ActiveHospitalizationsCount.ToString()" Description="Активные госпитализации" />
        <DashboardCard Title="Критические остатки" Value="@dashboard.LowStockItemsCount.ToString()" Description="Нужно проверить склад" />
        <DashboardCard Title="Вакцинации" Value="@dashboard.UpcomingVaccinationsCount.ToString()" Description="Ближайшие 30 дней" />
    </div>

    <section class="section-card">
        <h2>Последние записи на приём</h2>
        @if (dashboard.RecentAppointments.Count == 0)
        {
            <EmptyState Title="Записей на приём пока нет" Message="Последние записи появятся здесь после создания приёмов." />
        }
        else
        {
            <table class="table">
                <thead>
                    <tr>
                        <th>Дата</th>
                        <th>Питомец</th>
                        <th>Врач</th>
                        <th>Услуга</th>
                        <th>Статус</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var appointment in dashboard.RecentAppointments)
                    {
                        <tr>
                            <td>@appointment.StartAt.ToString("dd.MM.yyyy HH:mm")</td>
                            <td>@UiText.Value(appointment.PetName)</td>
                            <td>@UiText.Value(appointment.VeterinarianFullName)</td>
                            <td>@UiText.Value(appointment.ServiceName)</td>
                            <td><StatusBadge Status="@appointment.Status" /></td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </section>

    <section class="section-card">
        <h2>Загрузка врачей сегодня</h2>
        @if (dashboard.DoctorsLoad.Count == 0)
        {
            <EmptyState Title="На сегодня записей нет" Message="Нагрузка врачей появится после создания записей на приём." />
        }
        else
        {
            <table class="table">
                <thead>
                    <tr>
                        <th>Врач</th>
                        <th>Приёмов</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in dashboard.DoctorsLoad)
                    {
                        <tr>
                            <td>@UiText.Value(item.VeterinarianFullName)</td>
                            <td>@item.AppointmentsCount</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </section>

    <section class="section-card">
        <h2>Складские предупреждения</h2>
        @if (dashboard.LowStockItems.Count == 0)
        {
            <EmptyState Title="Критических остатков нет" Message="Все складские позиции выше минимального остатка." />
        }
        else
        {
            <table class="table">
                <thead>
                    <tr>
                        <th>Позиция</th>
                        <th>Остаток</th>
                        <th>Минимум</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in dashboard.LowStockItems)
                    {
                        <tr>
                            <td>@UiText.Value(item.Name)</td>
                            <td>@UiText.Quantity(item.Quantity, item.Unit)</td>
                            <td>@UiText.Quantity(item.MinQuantity, item.Unit)</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </section>

    <section class="section-card">
        <h2>Ближайшие вакцинации</h2>
        @if (dashboard.UpcomingVaccinations.Count == 0)
        {
            <EmptyState Title="Ближайших вакцинаций нет" Message="На ближайшие 30 дней вакцинации не запланированы." />
        }
        else
        {
            <table class="table">
                <thead>
                    <tr>
                        <th>Дата</th>
                        <th>Питомец</th>
                        <th>Вакцинация</th>
                        <th>Владелец</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var vaccination in dashboard.UpcomingVaccinations)
                    {
                        <tr>
                            <td>@UiText.Date(vaccination.NextDueAt, withTime: false)</td>
                            <td>@UiText.Value(vaccination.PetName)</td>
                            <td>@UiText.Value(vaccination.Name)</td>
                            <td>@UiText.Value(vaccination.OwnerFullName)</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </section>
}

@code {
    private AdminDashboardResponse? dashboard;
    private string message = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        SignalRNotificationService.NotificationReceived += OnNotificationReceived;
        await SignalRNotificationService.StartAsync();
        await LoadDashboardAsync();
    }

    private async Task LoadDashboardAsync()
    {
        dashboard = await AdminDashboardApiService.GetDashboardAsync();
        message = dashboard is null ? "Не удалось загрузить данные. Попробуйте обновить страницу." : string.Empty;
    }

    private void OnNotificationReceived(NotificationResponse notification)
    {
        _ = InvokeAsync(async () =>
        {
            await LoadDashboardAsync();
            StateHasChanged();
        });
    }

    public void Dispose()
    {
        SignalRNotificationService.NotificationReceived -= OnNotificationReceived;
    }
}
