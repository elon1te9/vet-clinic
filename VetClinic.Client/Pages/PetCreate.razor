@page "/pets/create"
@inject VetClinic.Client.Services.PetApiService PetApiService
@inject NavigationManager Navigation

<PageTitle>Новый питомец</PageTitle>

<PageHeader Title="Новый питомец" Description="Добавьте карточку питомца и основные сведения о нём." />

<section class="section-card pet-form-card">
    <div class="pet-form-layout">
        <div class="pet-main-fields">
            <div>
                <label>Имя</label>
                <input @bind="name" placeholder="Кличка питомца, например Барсик" />
            </div>

            <div>
                <label>Вид</label>
                <input @bind="species" placeholder="Например: кошка, собака, попугай" />
            </div>

            <div>
                <label>Порода</label>
                <input @bind="breed" placeholder="Например: британская короткошёрстная" />
            </div>

            <div>
                <label>Пол</label>
                <select @bind="gender">
                    <option value="Unknown">Не указан</option>
                    <option value="Male">Самец</option>
                    <option value="Female">Самка</option>
                </select>
            </div>

            <div>
                <label>Дата рождения</label>
                <InputDate @bind-Value="birthDate" />
            </div>

            <div>
                <label>Вес</label>
                <input @bind="weightText" placeholder="Вес в кг, например 4,5" />
            </div>
        </div>

        <div class="pet-notes-fields">
            <div>
                <label>Окрас</label>
                <input @bind="color" placeholder="Например: рыжий, серый, трёхцветный" />
            </div>

            <div class="pet-health-field">
                <label>Особенности здоровья</label>
                <textarea @bind="healthNotes" placeholder="Аллергии, хронические болезни или важные заметки"></textarea>
            </div>
        </div>
    </div>

    <ErrorMessage Text="@message" />

    <div class="actions-row">
        <button class="btn btn-primary" @onclick="CreatePet" type="button">Создать</button>
        <a class="btn btn-secondary" href="pets">Назад</a>
    </div>
</section>

@code {
    private string name = string.Empty;
    private string species = string.Empty;
    private string breed = string.Empty;
    private string gender = "Unknown";
    private DateTime? birthDate;
    private string weightText = string.Empty;
    private string color = string.Empty;
    private string healthNotes = string.Empty;
    private string message = string.Empty;

    private async Task CreatePet()
    {
        if (string.IsNullOrWhiteSpace(name) || string.IsNullOrWhiteSpace(species))
        {
            message = "Заполните имя и вид питомца.";
            return;
        }

        if (birthDate.HasValue && birthDate.Value.Date > DateTime.Today)
        {
            message = "Введите корректную дату.";
            return;
        }

        Enum.TryParse<VetClinic.Shared.Enums.PetGender>(gender, out var petGender);
        if (!TryReadWeight(out var weight))
        {
            message = "Введите корректный вес животного";
            return;
        }

        var result = await PetApiService.CreateAsync(new VetClinic.Shared.Requests.CreatePetRequest
        {
            Name = name,
            Species = species,
            Breed = string.IsNullOrWhiteSpace(breed) ? null : breed,
            Gender = petGender,
            BirthDate = birthDate,
            Weight = weight,
            Color = string.IsNullOrWhiteSpace(color) ? null : color,
            HealthNotes = string.IsNullOrWhiteSpace(healthNotes) ? null : healthNotes
        });

        if (result is null)
        {
            message = "Не удалось сохранить данные. Проверьте заполнение формы.";
            return;
        }

        Navigation.NavigateTo("/pets");
    }

    private bool TryReadWeight(out decimal? weight)
    {
        weight = null;

        if (string.IsNullOrWhiteSpace(weightText))
        {
            return true;
        }

        weightText = weightText.Trim().Replace('.', ',');
        if (decimal.TryParse(
            weightText,
            System.Globalization.NumberStyles.Number,
            System.Globalization.CultureInfo.GetCultureInfo("ru-RU"),
            out var parsedWeight))
        {
            if (parsedWeight < 0)
            {
                return false;
            }

            weight = parsedWeight;
            return true;
        }

        return false;
    }
}
