@page "/pets/create"
@inject VetClinic.Client.Services.PetApiService PetApiService
@inject NavigationManager Navigation

<PageTitle>Новый питомец</PageTitle>

<PageHeader Title="Новый питомец" Description="Добавьте карточку питомца и основные сведения о нём." />

<section class="section-card">
    <div class="form-grid">
        <div>
            <label>Имя</label>
            <input @bind="name" placeholder="Например: Барсик" />
        </div>

        <div>
            <label>Вид</label>
            <input @bind="species" placeholder="Кошка, собака, попугай" />
        </div>
    </div>

    <div class="form-grid">
        <div>
            <label>Порода</label>
            <input @bind="breed" placeholder="Порода" />
        </div>

        <div>
            <label>Пол</label>
            <select @bind="gender">
                <option value="Unknown">Не указан</option>
                <option value="Male">Самец</option>
                <option value="Female">Самка</option>
            </select>
        </div>
    </div>

    <div class="form-grid">
        <div>
            <label>Дата рождения</label>
            <InputDate @bind-Value="birthDate" />
        </div>

        <div>
            <label>Вес</label>
            <input @bind="weightText" placeholder="Например: 4,5" />
        </div>
    </div>

    <div>
        <label>Окрас</label>
        <input @bind="color" placeholder="Окрас" />
    </div>

    <div>
        <label>Особенности здоровья</label>
        <input @bind="healthNotes" placeholder="Краткие особенности здоровья" />
    </div>

    <ErrorMessage Text="@message" />

    <div class="actions-row">
        <button class="btn btn-primary" @onclick="CreatePet" type="button">Сохранить</button>
        <a class="btn btn-secondary" href="pets">Назад</a>
    </div>
</section>

@code {
    private string name = string.Empty;
    private string species = string.Empty;
    private string breed = string.Empty;
    private string gender = "Unknown";
    private DateTime? birthDate;
    private string weightText = string.Empty;
    private string color = string.Empty;
    private string healthNotes = string.Empty;
    private string message = string.Empty;

    private async Task CreatePet()
    {
        if (string.IsNullOrWhiteSpace(name) || string.IsNullOrWhiteSpace(species))
        {
            message = "Заполните имя и вид питомца.";
            return;
        }

        Enum.TryParse<VetClinic.Shared.Enums.PetGender>(gender, out var petGender);
        decimal.TryParse(weightText, out var weight);

        var result = await PetApiService.CreateAsync(new VetClinic.Shared.Requests.CreatePetRequest
        {
            Name = name,
            Species = species,
            Breed = string.IsNullOrWhiteSpace(breed) ? null : breed,
            Gender = petGender,
            BirthDate = birthDate,
            Weight = string.IsNullOrWhiteSpace(weightText) ? null : weight,
            Color = string.IsNullOrWhiteSpace(color) ? null : color,
            HealthNotes = string.IsNullOrWhiteSpace(healthNotes) ? null : healthNotes
        });

        if (result is null)
        {
            message = "Не удалось создать питомца.";
            return;
        }

        Navigation.NavigateTo("/pets");
    }
}
