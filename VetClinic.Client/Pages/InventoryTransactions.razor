@page "/inventory/transactions"
@inject VetClinic.Client.Services.InventoryApiService InventoryApiService
@inject VetClinic.Client.Services.MedicalRecordApiService MedicalRecordApiService
@inject VetClinic.Client.Services.LocalStorageService LocalStorageService

<PageTitle>Операции склада</PageTitle>

<PageHeader Title="Операции склада" Description="Журнал поступлений, списаний, выдач и корректировок." />

<ErrorMessage Text="@message" />

<section class="section-card">
@if (role == "Admin" || role == "Assistant")
{
    <div class="inline-create-panel inventory-operation-panel">
        <div class="section-title-row">
            <h2>Новая операция</h2>
        </div>

        @if (items.Count == 0)
        {
            <EmptyState Title="Сначала создайте складскую позицию" Message="После создания позиции можно будет добавить операцию склада." />
        }
        else
        {
            <div class="inventory-operation-layout">
                <div class="inventory-operation-main">
                    <div>
                        <label>Складская позиция</label>
                        <select @bind="inventoryItemId">
                            @foreach (var item in items)
                            {
                                <option value="@item.Id">@item.Name (@UiText.Quantity(item.Quantity, item.Unit))</option>
                            }
                        </select>
                    </div>

                    <div>
                        <label>Медицинская запись</label>
                        <select @bind="relatedMedicalRecordId">
                            <option value="">Не связывать с медицинской записью</option>
                            @foreach (var record in medicalRecords)
                            {
                                <option value="@record.Id">@UiText.Date(record.VisitDate, withTime: false) — @record.PetName</option>
                            }
                        </select>
                    </div>
                </div>

                <div class="inventory-operation-side">
                    <div class="inventory-operation-params">
                        <div>
                            <label>Тип операции</label>
                            <select @bind="typeText">
                                @foreach (var type in Enum.GetValues<VetClinic.Shared.Enums.InventoryTransactionType>())
                                {
                                    <option value="@type">@UiText.Status(type)</option>
                                }
                            </select>
                        </div>

                        <div>
                            <label>Количество</label>
                            <input type="number" step="0.01" @bind="quantity" placeholder="Количество" />
                        </div>
                    </div>

                    <div>
                        <label>Причина</label>
                        <textarea @bind="reason" placeholder="Кратко укажите причину операции"></textarea>
                    </div>

                    <div class="actions-row">
                        <button class="btn btn-primary" @onclick="CreateTransaction" type="button">Создать</button>
                    </div>
                </div>
            </div>
        }
    </div>
}

<h2>Журнал операций</h2>
@if (transactions.Count == 0)
{
    <EmptyState Title="Операций склада пока нет" Message="После поступлений, расходов, списаний или корректировок записи появятся в журнале." />
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>Дата</th>
                <th>Позиция</th>
                <th>Тип</th>
                <th>Количество</th>
                <th>Причина</th>
                <th>Пользователь</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var transaction in transactions)
            {
                <tr>
                    <td>@UiText.Date(transaction.CreatedAt)</td>
                    <td>@UiText.Value(transaction.InventoryItemName)</td>
                    <td><StatusBadge Status="@transaction.Type" /></td>
                    <td>@transaction.Quantity</td>
                    <td>@UiText.Value(transaction.Reason)</td>
                    <td>@UiText.Value(transaction.CreatedByUserFullName)</td>
                </tr>
            }
        </tbody>
    </table>
}
</section>

@code {
    private List<VetClinic.Shared.Responses.InventoryItemResponse> items = [];
    private List<VetClinic.Shared.Responses.InventoryTransactionResponse> transactions = [];
    private List<VetClinic.Shared.Responses.MedicalRecordResponse> medicalRecords = [];
    private string role = string.Empty;
    private int inventoryItemId;
    private string typeText = VetClinic.Shared.Enums.InventoryTransactionType.Outgoing.ToString();
    private decimal quantity = 1;
    private string reason = string.Empty;
    private int? relatedMedicalRecordId;
    private string message = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        role = await LocalStorageService.GetItemAsync("role") ?? string.Empty;
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        items = await InventoryApiService.GetAllAsync();
        transactions = await InventoryApiService.GetTransactionsAsync();
        medicalRecords = await MedicalRecordApiService.GetAllAsync();
        inventoryItemId = items.FirstOrDefault()?.Id ?? 0;
    }

    private async Task CreateTransaction()
    {
        if (inventoryItemId <= 0 || quantity <= 0)
        {
            message = "Выберите позицию и укажите количество.";
            return;
        }

        Enum.TryParse<VetClinic.Shared.Enums.InventoryTransactionType>(typeText, out var type);

        var result = await InventoryApiService.CreateTransactionAsync(new VetClinic.Shared.Requests.CreateInventoryTransactionRequest
        {
            InventoryItemId = inventoryItemId,
            Type = type,
            Quantity = quantity,
            Reason = string.IsNullOrWhiteSpace(reason) ? null : reason,
            RelatedMedicalRecordId = relatedMedicalRecordId
        });

        if (result is null)
        {
            message = "Не удалось сохранить данные. Проверьте заполнение формы.";
            return;
        }

        reason = string.Empty;
        relatedMedicalRecordId = null;
        message = "Операция создана.";

        await LoadAsync();
    }
}
