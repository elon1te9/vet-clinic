@page "/hospitalizations"
@inject VetClinic.Client.Services.HospitalizationApiService HospitalizationApiService
@inject VetClinic.Client.Services.PetApiService PetApiService
@inject VetClinic.Client.Services.LocalStorageService LocalStorageService

<PageTitle>Стационар</PageTitle>

<PageHeader Title="Стационар" Description="Госпитализации питомцев и текущие записи ухода." />

<ErrorMessage Text="@message" />

<section class="section-card">
@if (CanManageHospitalizations)
{
    <div class="inline-create-panel hospitalization-create-panel">
        <div class="section-title-row">
            <h2>Новая госпитализация</h2>
        </div>

        <div class="hospitalization-create-layout">
            <div class="hospitalization-create-main">
                <div>
                    <label>Питомец</label>
                    <select @bind="petId">
                        @foreach (var pet in pets)
                        {
                            <option value="@pet.Id">@pet.Name</option>
                        }
                    </select>
                </div>

                <div>
                    <label>Палата</label>
                    <input @bind="wardNumber" placeholder="Например: А-101" />
                </div>
            </div>

            <div class="hospitalization-create-notes">
                <div>
                    <label>Режим кормления</label>
                    <input @bind="feedingSchedule" placeholder="Например: 2 раза в день" />
                </div>

                <div>
                    <label>Состояние</label>
                    <textarea @bind="conditionNotes" placeholder="Кратко опишите состояние питомца"></textarea>
                </div>

                <div class="actions-row">
                    <button class="btn btn-primary" @onclick="CreateHospitalization" type="button">Создать</button>
                </div>
            </div>
        </div>
    </div>
}

<h2>Госпитализации</h2>
@if (hospitalizations.Count == 0)
{
    <EmptyState Title="Госпитализаций пока нет" Message="Создайте госпитализацию, чтобы отслеживать палату, состояние и записи ухода." />
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>Питомец</th>
                <th>Начало</th>
                <th>Окончание</th>
                <th>Палата</th>
                <th>Статус</th>
                <th class="table-actions-cell"></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in hospitalizations)
            {
                <tr>
                    <td>@UiText.Value(item.PetName)</td>
                    <td>@UiText.Date(item.StartAt)</td>
                    <td>@UiText.Date(item.EndAt)</td>
                    <td>@UiText.Value(item.WardNumber)</td>
                    <td><StatusBadge Status="@item.Status" /></td>
                    <td class="table-actions-cell">
                        <a class="btn btn-secondary btn-sm" href="@($"hospitalizations/{item.Id}")">Открыть</a>
                        @if (CanManageHospitalizations && item.Status == VetClinic.Shared.Enums.HospitalizationStatus.Active)
                        {
                            <button class="btn btn-danger btn-sm" @onclick="() => CloseHospitalization(item.Id)" type="button">Закрыть</button>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
</section>

@code {
    private List<VetClinic.Shared.Responses.PetResponse> pets = [];
    private List<VetClinic.Shared.Responses.HospitalizationResponse> hospitalizations = [];
    private int petId;
    private string wardNumber = string.Empty;
    private string feedingSchedule = string.Empty;
    private string conditionNotes = string.Empty;
    private string role = string.Empty;
    private string message = string.Empty;
    private bool CanManageHospitalizations => role == "Admin" || role == "Veterinarian" || role == "Assistant";

    protected override async Task OnInitializedAsync()
    {
        role = await LocalStorageService.GetItemAsync("role") ?? string.Empty;
        pets = await PetApiService.GetAllAsync();
        petId = pets.FirstOrDefault()?.Id ?? 0;
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        hospitalizations = await HospitalizationApiService.GetAllAsync();
    }

    private async Task CreateHospitalization()
    {
        if (petId <= 0 || string.IsNullOrWhiteSpace(wardNumber))
        {
            message = "Выберите питомца и укажите палату.";
            return;
        }

        var result = await HospitalizationApiService.CreateAsync(new VetClinic.Shared.Requests.CreateHospitalizationRequest
        {
            PetId = petId,
            WardNumber = wardNumber,
            FeedingSchedule = string.IsNullOrWhiteSpace(feedingSchedule) ? null : feedingSchedule,
            ConditionNotes = string.IsNullOrWhiteSpace(conditionNotes) ? null : conditionNotes
        });

        message = result is null ? "Не удалось сохранить данные. Проверьте заполнение формы." : "Госпитализация создана.";

        if (result is not null)
        {
            wardNumber = string.Empty;
            feedingSchedule = string.Empty;
            conditionNotes = string.Empty;
        }

        await LoadAsync();
    }

    private async Task CloseHospitalization(int id)
    {
        var result = await HospitalizationApiService.CloseAsync(id);
        message = result is null ? "Не удалось закрыть госпитализацию." : "Госпитализация закрыта.";

        await LoadAsync();
    }
}
