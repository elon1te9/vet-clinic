@page "/"
@inject VetClinic.Client.Services.LocalStorageService LocalStorageService

<PageTitle>Главная</PageTitle>

@if (!isAuthorized)
{
    <section class="home-hero">
        <div class="home-panel home-main-panel">
            <PageHeader Title="VetClinic — система управления ветеринарной клиникой"
                        Description="Единое рабочее пространство для записи на приём, ведения медицинских карт, учёта вакцинаций, склада и финансов клиники." />

            <div class="actions-row">
                <a class="btn btn-primary" href="login">Войти</a>
                <a class="btn btn-secondary" href="register">Зарегистрироваться</a>
            </div>
        </div>

        <div class="home-panel">
            <h2>Для ежедневной работы клиники</h2>
            <p>Интерфейс помогает администраторам, врачам, ассистентам и владельцам питомцев быстро находить нужные разделы и работать с актуальными данными.</p>
        </div>
    </section>

    <div class="feature-grid">
        <div class="feature-card">
            <h3>Онлайн-запись на приём</h3>
            <p>Выбор питомца, врача, услуги и удобного времени в одном понятном сценарии.</p>
        </div>
        <div class="feature-card">
            <h3>Электронные медицинские карты</h3>
            <p>История визитов, диагнозы, назначения и рекомендации по каждому питомцу.</p>
        </div>
        <div class="feature-card">
            <h3>Вакцинации и напоминания</h3>
            <p>Планирование следующих дат и контроль просроченных вакцинаций.</p>
        </div>
        <div class="feature-card">
            <h3>Склад и финансы клиники</h3>
            <p>Остатки, операции склада, счета и финансовые отчёты в едином стиле.</p>
        </div>
    </div>
}
else
{
    <section class="home-hero">
        <div class="home-panel home-main-panel">
            <PageHeader Title="@WelcomeTitle"
                        Description="Выберите нужный раздел в меню или используйте быстрые действия." />
        </div>

        <div class="home-panel">
            <h2>Быстрые действия</h2>
            <p>Самые частые разделы собраны рядом, чтобы не искать их в меню.</p>
        </div>
    </section>

    <div class="quick-grid">
        @foreach (var link in quickLinks)
        {
            <a class="quick-card" href="@link.Href">
                <h3>@link.Title</h3>
                <p>@link.Description</p>
            </a>
        }
    </div>
}

@code {
    private bool isAuthorized;
    private string role = string.Empty;
    private string fullName = string.Empty;
    private List<QuickLink> quickLinks = [];

    private string WelcomeTitle => string.IsNullOrWhiteSpace(fullName)
        ? "Добро пожаловать"
        : $"Здравствуйте, {fullName}";

    protected override async Task OnInitializedAsync()
    {
        var token = await LocalStorageService.GetItemAsync("token");
        isAuthorized = !string.IsNullOrWhiteSpace(token);
        role = await LocalStorageService.GetItemAsync("role") ?? string.Empty;
        fullName = await LocalStorageService.GetItemAsync("fullName") ?? string.Empty;
        quickLinks = GetLinksForRole(role);
    }

    private static List<QuickLink> GetLinksForRole(string currentRole)
    {
        if (currentRole == "Admin")
        {
            return
            [
                new("Админ-панель", "Сводка по клинике и ключевым показателям.", "admin/dashboard"),
                new("Расписание", "Записи на приём и статусы визитов.", "appointments"),
                new("Склад", "Остатки, сроки годности и позиции склада.", "inventory"),
                new("Отчёты", "Финансы и операционная аналитика.", "reports")
            ];
        }

        if (currentRole == "Veterinarian")
        {
            return
            [
                new("Мои записи", "Приёмы, назначенные врачу.", "appointments/my"),
                new("Медицинские карты", "История осмотров и назначений.", "medical-records"),
                new("Вакцинации", "План и история вакцинаций.", "vaccinations"),
                new("Операции", "Планирование и статусы операций.", "surgeries")
            ];
        }

        if (currentRole == "Owner")
        {
            return
            [
                new("Мои питомцы", "Карточки и данные питомцев.", "pets"),
                new("Записаться на приём", "Выбор врача, услуги и времени.", "appointments/create"),
                new("Мои записи", "Предстоящие и прошедшие приёмы.", "appointments/my"),
                new("Счета", "Счета за услуги клиники.", "invoices")
            ];
        }

        if (currentRole == "Assistant")
        {
            return
            [
                new("Расписание", "Приёмы клиники на выбранные дни.", "appointments"),
                new("Склад", "Остатки и складские позиции.", "inventory"),
                new("Стационар", "Госпитализации и уход за питомцами.", "hospitalizations"),
                new("Уведомления", "Новые события и задачи.", "notifications")
            ];
        }

        return [];
    }

    private record QuickLink(string Title, string Description, string Href);
}
