@page "/pets"
@inject VetClinic.Client.Services.PetApiService PetApiService
@inject VetClinic.Client.Services.LocalStorageService LocalStorageService
@inject NavigationManager Navigation

<PageTitle>Питомцы</PageTitle>

<PageHeader Title="Питомцы" Description="Карточки питомцев и основные данные владельцев.">
    <Actions>
        @if (canCreate)
        {
            <button class="btn btn-primary" @onclick="OpenCreatePage" type="button">Добавить питомца</button>
        }
    </Actions>
</PageHeader>

<ErrorMessage Text="@message" />

<section class="section-card">
    @if (pets.Count == 0)
    {
        <EmptyState Title="Питомцы пока не добавлены" Message="Создайте карточку питомца, чтобы записывать его на приёмы и вести медицинскую историю." />
    }
    else
    {
        <table class="table">
            <thead>
                <tr>
                    <th>Имя</th>
                    <th>Вид</th>
                    <th>Порода</th>
                    @if (role != "Owner")
                    {
                        <th>Владелец</th>
                    }
                    <th class="table-actions-cell"></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var pet in pets)
                {
                    <tr>
                        <td>@UiText.Value(pet.Name)</td>
                        <td>@UiText.Value(pet.Species)</td>
                        <td>@UiText.Value(pet.Breed)</td>
                        @if (role != "Owner")
                        {
                            <td>@UiText.Value(pet.OwnerFullName)</td>
                        }
                        <td class="table-actions-cell">
                            <button class="btn btn-secondary btn-sm" @onclick="() => OpenDetails(pet.Id)" type="button">Открыть</button>
                            @if (canEdit)
                            {
                                <button class="btn btn-secondary btn-sm" @onclick="() => OpenEdit(pet.Id)" type="button">Изменить</button>
                                <button class="btn btn-danger btn-sm" @onclick="() => DeletePet(pet.Id)" type="button">Удалить</button>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</section>

@code {
    private List<VetClinic.Shared.Responses.PetResponse> pets = [];
    private string role = string.Empty;
    private string message = string.Empty;

    private bool canCreate => role == "Owner" || role == "Admin";
    private bool canEdit => role == "Owner" || role == "Admin";

    protected override async Task OnInitializedAsync()
    {
        role = await LocalStorageService.GetItemAsync("role") ?? string.Empty;
        await LoadPetsAsync();
    }

    private async Task LoadPetsAsync()
    {
        message = string.Empty;
        pets = role == "Owner"
            ? await PetApiService.GetMyAsync()
            : await PetApiService.GetAllAsync();
    }

    private void OpenCreatePage()
    {
        Navigation.NavigateTo("/pets/create");
    }

    private void OpenDetails(int id)
    {
        Navigation.NavigateTo($"/pets/{id}");
    }

    private void OpenEdit(int id)
    {
        Navigation.NavigateTo($"/pets/edit/{id}");
    }

    private async Task DeletePet(int id)
    {
        var result = await PetApiService.DeleteAsync(id);
        message = result ? string.Empty : "Не удалось удалить питомца. Попробуйте обновить страницу.";
        await LoadPetsAsync();
    }
}
