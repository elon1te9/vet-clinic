@page "/inventory/edit/{Id:int}"
@inject VetClinic.Client.Services.InventoryApiService InventoryApiService
@inject NavigationManager NavigationManager

<PageTitle>Редактирование склада</PageTitle>

<PageHeader Title="Редактирование склада" Description="Обновите данные складской позиции." />

<ErrorMessage Text="@message" />

<section class="section-card">
@if (loaded)
{
    <div>
        <label>Название</label>
        <input @bind="name" placeholder="Название позиции" />
    </div>

    <div>
        <label>Категория</label>
        <select @bind="categoryText">
            @foreach (var category in Enum.GetValues<VetClinic.Shared.Enums.InventoryCategory>())
            {
                <option value="@category">@category</option>
            }
        </select>
    </div>

    <div>
        <label>Единица</label>
        <input @bind="unit" placeholder="шт., уп., мл." />
    </div>

    <div>
        <label>Количество</label>
        <input type="number" step="0.01" @bind="quantity" placeholder="0" />
    </div>

    <div>
        <label>Минимум</label>
        <input type="number" step="0.01" @bind="minQuantity" placeholder="0" />
    </div>

    <div>
        <label>Срок годности</label>
        <InputDate @bind-Value="expirationDate" />
    </div>

    <div>
        <label>Цена</label>
        <input type="number" step="0.01" @bind="price" placeholder="0" />
    </div>

    <div>
        <label>Поставщик</label>
        <input @bind="supplier" placeholder="Поставщик" />
    </div>

    <div>
        <label>
            <input type="checkbox" @bind="isActive" />
            Активна
        </label>
    </div>

    <button class="btn btn-primary" @onclick="UpdateItem" type="button">Сохранить</button>
}
</section>

@code {
    [Parameter] public int Id { get; set; }

    private bool loaded;
    private string name = string.Empty;
    private string categoryText = VetClinic.Shared.Enums.InventoryCategory.Medicine.ToString();
    private string unit = string.Empty;
    private decimal quantity;
    private decimal minQuantity;
    private DateTime? expirationDate;
    private decimal price;
    private string supplier = string.Empty;
    private bool isActive = true;
    private string message = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        var item = await InventoryApiService.GetByIdAsync(Id);
        if (item is null)
        {
            message = "Позиция не найдена.";
            return;
        }

        name = item.Name;
        categoryText = item.Category.ToString();
        unit = item.Unit;
        quantity = item.Quantity;
        minQuantity = item.MinQuantity;
        expirationDate = item.ExpirationDate;
        price = item.Price;
        supplier = item.Supplier ?? string.Empty;
        isActive = item.IsActive;
        loaded = true;
    }

    private async Task UpdateItem()
    {
        Enum.TryParse<VetClinic.Shared.Enums.InventoryCategory>(categoryText, out var category);

        var result = await InventoryApiService.UpdateAsync(Id, new VetClinic.Shared.Requests.UpdateInventoryItemRequest
        {
            Name = name,
            Category = category,
            Unit = unit,
            Quantity = quantity,
            MinQuantity = minQuantity,
            ExpirationDate = expirationDate,
            Price = price,
            Supplier = string.IsNullOrWhiteSpace(supplier) ? null : supplier,
            IsActive = isActive
        });

        if (result is null)
        {
            message = "Не удалось сохранить позицию.";
            return;
        }

        NavigationManager.NavigateTo("inventory");
    }
}
