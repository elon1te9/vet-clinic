@page "/reports"
@using VetClinic.Shared.Responses
@inject VetClinic.Client.Services.ReportApiService ReportApiService

<PageTitle>Отчёты</PageTitle>

<PageHeader Title="Отчёты"
            Description="Финансовая и операционная сводка клиники за выбранный период." />

<section class="section-card reports-filter-card">
    <div class="section-title-row">
        <h2>Период отчёта</h2>
    </div>
    <div class="reports-filter-grid">
        <div>
            <label>С</label>
            <input type="date" @bind="from" />
        </div>
        <div>
            <label>По</label>
            <input type="date" @bind="to" />
        </div>
        <div class="actions-row">
            <button class="btn btn-primary" type="button" @onclick="LoadReportsAsync">Показать</button>
        </div>
    </div>
</section>

<ErrorMessage Text="@message" />

@if (revenue is not null)
{
    <div class="reports-kpi-grid">
        <div class="reports-kpi-card">
            <span>Выручка</span>
            <strong>@UiText.Money(revenue.TotalRevenue)</strong>
            <p>Сумма оплаченных счетов</p>
        </div>
        <div class="reports-kpi-card">
            <span>Оплаченных счетов</span>
            <strong>@revenue.PaidInvoicesCount</strong>
            <p>За выбранный период</p>
        </div>
    </div>
}

<div class="reports-grid">
    <section class="section-card reports-section">
        <div class="section-title-row">
            <h2>Нагрузка врачей</h2>
        </div>
        @if (doctorLoad.Count == 0)
        {
            <EmptyState Title="За выбранный период данных нет" Message="Измените даты отчёта или проверьте период, когда были приёмы." />
        }
        else
        {
            <table class="table reports-table">
                <colgroup>
                    <col class="reports-table-main-column" />
                    <col class="reports-table-value-column" />
                </colgroup>
                <thead>
                    <tr>
                        <th>Врач</th>
                        <th>Приёмов</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in doctorLoad)
                    {
                        <tr>
                            <td>@UiText.Value(item.VeterinarianFullName)</td>
                            <td>@item.AppointmentsCount</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </section>

    <section class="section-card reports-section">
        <div class="section-title-row">
            <h2>Популярные услуги</h2>
        </div>
        @if (popularServices.Count == 0)
        {
            <EmptyState Title="За выбранный период данных нет" Message="Услуги появятся в отчёте после созданных приёмов." />
        }
        else
        {
            <table class="table reports-table">
                <colgroup>
                    <col class="reports-table-main-column" />
                    <col class="reports-table-value-column" />
                </colgroup>
                <thead>
                    <tr>
                        <th>Услуга</th>
                        <th>Приёмов</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in popularServices)
                    {
                        <tr>
                            <td>@UiText.Value(item.ServiceName)</td>
                            <td>@item.AppointmentsCount</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </section>

    <section class="section-card reports-section">
        <div class="section-title-row">
            <h2>Расход склада</h2>
        </div>
        @if (inventoryUsage.Count == 0)
        {
            <EmptyState Title="За выбранный период данных нет" Message="Расходы склада появятся после операций типа «Расход» или «Списание»." />
        }
        else
        {
            <table class="table reports-table">
                <colgroup>
                    <col class="reports-table-main-column" />
                    <col class="reports-table-value-column" />
                </colgroup>
                <thead>
                    <tr>
                        <th>Позиция</th>
                        <th>Количество</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in inventoryUsage)
                    {
                        <tr>
                            <td>@UiText.Value(item.InventoryItemName)</td>
                            <td>@item.QuantityUsed.ToString("0.##")</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </section>

    <section class="section-card reports-section">
        <div class="section-title-row">
            <h2>Сводка приёмов</h2>
        </div>
        @if (appointmentsSummary.Count == 0)
        {
            <EmptyState Title="За выбранный период данных нет" Message="Сводка появится после создания записей на приём." />
        }
        else
        {
            <table class="table reports-table">
                <colgroup>
                    <col class="reports-table-main-column" />
                    <col class="reports-table-value-column" />
                </colgroup>
                <thead>
                    <tr>
                        <th>Статус</th>
                        <th>Количество</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in appointmentsSummary)
                    {
                        <tr>
                            <td><StatusBadge Status="@item.Status" /></td>
                            <td>@item.Count</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </section>
</div>

@code {
    private DateTime from = DateTime.Today.AddMonths(-1);
    private DateTime to = DateTime.Today;
    private RevenueReportResponse? revenue;
    private List<DoctorLoadReportResponse> doctorLoad = [];
    private List<PopularServiceReportResponse> popularServices = [];
    private List<InventoryUsageReportResponse> inventoryUsage = [];
    private List<AppointmentsSummaryReportResponse> appointmentsSummary = [];
    private string message = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        await LoadReportsAsync();
    }

    private async Task LoadReportsAsync()
    {
        if (from > to)
        {
            message = "Дата начала не может быть больше даты окончания.";
            return;
        }

        message = string.Empty;
        revenue = await ReportApiService.GetRevenueAsync(from, to);
        doctorLoad = await ReportApiService.GetDoctorLoadAsync(from, to);
        popularServices = await ReportApiService.GetPopularServicesAsync(from, to);
        inventoryUsage = await ReportApiService.GetInventoryUsageAsync(from, to);
        appointmentsSummary = await ReportApiService.GetAppointmentsSummaryAsync(from, to);
        message = revenue is null ? "Не удалось загрузить данные. Попробуйте обновить страницу." : string.Empty;
    }
}
