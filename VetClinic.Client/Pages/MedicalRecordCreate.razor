@page "/medical-records/create"
@inject VetClinic.Client.Services.MedicalRecordApiService MedicalRecordApiService
@inject VetClinic.Client.Services.PetApiService PetApiService
@inject VetClinic.Client.Services.AppointmentApiService AppointmentApiService
@inject VetClinic.Client.Services.LocalStorageService LocalStorageService
@inject NavigationManager Navigation

<PageTitle>Новая медицинская запись</PageTitle>

<PageHeader Title="Новая медицинская запись" Description="Создайте запись осмотра по выбранному питомцу и приёму." />

<section class="section-card medical-record-form-card">
    <div class="medical-record-form-layout">
        <div class="medical-record-basic-fields">
            <div>
                <label>Питомец</label>
                <select @bind="SelectedPetId">
                    @foreach (var pet in pets)
                    {
                        <option value="@pet.Id">@pet.Name</option>
                    }
                </select>
            </div>

            <div>
                <label>Приём</label>
                <select @bind="appointmentIdText">
                    <option value="">Без приёма</option>
                    @foreach (var appointment in FilteredAppointments)
                    {
                        <option value="@appointment.Id">@appointment.StartAt.ToString("dd.MM.yyyy HH:mm") - @appointment.PetName</option>
                    }
                </select>
            </div>

            <div>
                <label>Дата визита</label>
                <InputDate @bind-Value="visitDate" />
            </div>

            <div class="medical-record-vitals-grid">
                <div>
                    <label>Температура</label>
                    <input type="number" step="0.1" @bind="temperature" placeholder="Например: 38,5" />
                </div>

                <div>
                    <label>Вес</label>
                    <input type="number" step="0.1" @bind="weight" placeholder="Вес в кг" />
                </div>
            </div>
        </div>

        <div class="medical-record-notes-grid">
            <div>
                <label>Жалобы</label>
                <textarea @bind="complaints" placeholder="Опишите жалобы владельца"></textarea>
            </div>

            <div>
                <label>Диагноз</label>
                <textarea @bind="diagnosis" placeholder="Укажите диагноз"></textarea>
            </div>

            <div>
                <label>Лечение и назначения</label>
                <textarea @bind="treatment" placeholder="Назначения, препараты и план лечения"></textarea>
            </div>

            <div>
                <label>Рекомендации</label>
                <textarea @bind="recommendations" placeholder="Рекомендации владельцу"></textarea>
            </div>
        </div>
    </div>

<ErrorMessage Text="@message" />

<div class="actions-row">
    <button class="btn btn-primary" @onclick="CreateRecord" type="button">Создать</button>
    <a class="btn btn-secondary" href="medical-records">Назад</a>
</div>
</section>

@code {
    private List<VetClinic.Shared.Responses.PetResponse> pets = [];
    private List<VetClinic.Shared.Responses.AppointmentResponse> appointments = [];
    private int petId;
    private string appointmentIdText = string.Empty;
    private DateTime? visitDate = DateTime.Today;
    private string complaints = string.Empty;
    private string diagnosis = string.Empty;
    private string treatment = string.Empty;
    private string recommendations = string.Empty;
    private decimal? temperature;
    private decimal? weight;
    private string message = string.Empty;
    private string role = string.Empty;
    private List<VetClinic.Shared.Responses.AppointmentResponse> FilteredAppointments => appointments
        .Where(appointment =>
            appointment.PetId == petId &&
            appointment.Status != VetClinic.Shared.Enums.AppointmentStatus.Completed &&
            appointment.Status != VetClinic.Shared.Enums.AppointmentStatus.Cancelled)
        .OrderBy(appointment => appointment.StartAt)
        .ToList();

    private int SelectedPetId
    {
        get => petId;
        set
        {
            if (petId == value)
            {
                return;
            }

            petId = value;
            ResetAppointmentSelection();
        }
    }

    protected override async Task OnInitializedAsync()
    {
        role = await LocalStorageService.GetItemAsync("role") ?? string.Empty;

        pets = await PetApiService.GetAllAsync();
        appointments = role == "Admin"
            ? await AppointmentApiService.GetAllAsync()
            : await AppointmentApiService.GetMyAsync();

        petId = pets.FirstOrDefault()?.Id ?? 0;
        ResetAppointmentSelection();
    }

    private void ResetAppointmentSelection()
    {
        if (!FilteredAppointments.Any(appointment => appointment.Id.ToString() == appointmentIdText))
        {
            appointmentIdText = string.Empty;
        }
    }

    private async Task CreateRecord()
    {
        if (petId <= 0 || visitDate is null)
        {
            message = "Выберите питомца и дату визита.";
            return;
        }

        int? appointmentId = null;
        if (int.TryParse(appointmentIdText, out var parsedAppointmentId))
        {
            appointmentId = parsedAppointmentId;
        }

        if ((role == "Veterinarian" || role == "Admin") && !appointmentId.HasValue)
        {
            message = "Выберите приём для создания медицинской записи.";
            return;
        }

        var result = await MedicalRecordApiService.CreateAsync(new VetClinic.Shared.Requests.CreateMedicalRecordRequest
        {
            AppointmentId = appointmentId,
            PetId = petId,
            VisitDate = visitDate.Value,
            Complaints = string.IsNullOrWhiteSpace(complaints) ? null : complaints,
            Diagnosis = string.IsNullOrWhiteSpace(diagnosis) ? null : diagnosis,
            Treatment = string.IsNullOrWhiteSpace(treatment) ? null : treatment,
            Recommendations = string.IsNullOrWhiteSpace(recommendations) ? null : recommendations,
            Temperature = temperature,
            Weight = weight
        });

        if (result is null)
        {
            message = "Не удалось сохранить данные. Проверьте заполнение формы.";
            return;
        }

        Navigation.NavigateTo($"/medical-records/{result.Id}");
    }
}
