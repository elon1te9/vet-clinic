@page "/appointments/my"
@inject VetClinic.Client.Services.AppointmentApiService AppointmentApiService
@inject VetClinic.Client.Services.LocalStorageService LocalStorageService
@inject NavigationManager Navigation

<PageTitle>Мои записи</PageTitle>

<h1>Мои записи</h1>

@if (role == "Owner")
{
    <button @onclick="OpenCreatePage" type="button">Записаться на приём</button>
}

@if (!string.IsNullOrWhiteSpace(message))
{
    <p>@message</p>
}

@if (appointments.Count == 0)
{
    <p>Записи не найдены.</p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>Дата</th>
                <th>Питомец</th>
                <th>Врач</th>
                <th>Услуга</th>
                <th>Причина</th>
                <th>Статус</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var appointment in appointments)
            {
                <tr>
                    <td>@FormatDate(appointment.StartAt)</td>
                    <td>@appointment.PetName</td>
                    <td>@appointment.VeterinarianFullName</td>
                    <td>@appointment.ServiceName</td>
                    <td>@appointment.Reason</td>
                    <td><StatusBadge Status="@appointment.Status" /></td>
                    <td>
                        @if (role == "Owner")
                        {
                            <button class="btn-danger btn-sm" @onclick="() => CancelAppointment(appointment.Id)" type="button">Отменить</button>
                        }
                        @if (role == "Veterinarian")
                        {
                            <button class="btn-sm" @onclick="() => ChangeStatus(appointment.Id, VetClinic.Shared.Enums.AppointmentStatus.Confirmed)" type="button">Подтвердить</button>
                            <button class="btn-secondary btn-sm" @onclick="() => ChangeStatus(appointment.Id, VetClinic.Shared.Enums.AppointmentStatus.Completed)" type="button">Завершить</button>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<VetClinic.Shared.Responses.AppointmentResponse> appointments = [];
    private string role = string.Empty;
    private string message = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        role = await LocalStorageService.GetItemAsync("role") ?? string.Empty;
        await LoadAppointmentsAsync();
    }

    private async Task LoadAppointmentsAsync()
    {
        appointments = await AppointmentApiService.GetMyAsync();

        if (appointments.Count == 0)
        {
            message = "Список записей пока пуст.";
        }
    }

    private void OpenCreatePage()
    {
        Navigation.NavigateTo("/appointments/create");
    }

    private async Task CancelAppointment(int id)
    {
        var result = await AppointmentApiService.DeleteAsync(id);
        message = result ? "Запись отменена." : "Не удалось отменить запись.";
        await LoadAppointmentsAsync();
    }

    private async Task ChangeStatus(int id, VetClinic.Shared.Enums.AppointmentStatus status)
    {
        var result = await AppointmentApiService.UpdateStatusAsync(id, new VetClinic.Shared.Requests.UpdateAppointmentStatusRequest
        {
            Status = status
        });

        message = result is null ? "Не удалось изменить статус записи." : "Статус записи изменён.";
        await LoadAppointmentsAsync();
    }

    private static string FormatDate(DateTime value)
    {
        return value.ToLocalTime().ToString("dd.MM.yyyy HH:mm");
    }
}
