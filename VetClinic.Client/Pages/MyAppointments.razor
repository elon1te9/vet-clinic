@page "/appointments/my"
@inject VetClinic.Client.Services.AppointmentApiService AppointmentApiService
@inject VetClinic.Client.Services.LocalStorageService LocalStorageService
@inject NavigationManager Navigation

<PageTitle>Мои записи</PageTitle>

<PageHeader Title="Мои записи" Description="Записи на приём, доступные текущему пользователю.">
    <Actions>
        @if (role == "Owner")
        {
            <button class="btn btn-primary" @onclick="() => OpenCreatePage()" type="button">Записаться на приём</button>
        }
        else if (role == "Veterinarian")
        {
            <button class="btn btn-primary" @onclick="() => OpenCreatePage()" type="button">Записать на приём</button>
        }
    </Actions>
</PageHeader>

<ErrorMessage Text="@message" />

<section class="section-card">
    @if (appointments.Count == 0)
    {
        <EmptyState Title="Записей на приём пока нет" Message="Запишитесь на приём, чтобы увидеть дату, врача, услугу и статус визита." />
    }
    else
    {
        <div class="appointment-list">
            @foreach (var appointment in appointments)
            {
                <article class="appointment-card">
                    <div class="appointment-date-tile">
                        <span>@appointment.StartAt.ToString("dd.MM.yyyy")</span>
                        <strong>@appointment.StartAt.ToString("HH:mm")</strong>
                    </div>

                    <div class="appointment-card-body">
                        <div class="appointment-card-grid">
                            <div>
                                <span>Питомец</span>
                                <strong>@UiText.Value(appointment.PetName)</strong>
                            </div>

                            <div>
                                <span>Врач</span>
                                <strong>@UiText.Value(appointment.VeterinarianFullName)</strong>
                            </div>

                            <div>
                                <span>Услуга</span>
                                <strong>@UiText.Value(appointment.ServiceName)</strong>
                            </div>

                            <div class="appointment-card-reason">
                                <span>Причина</span>
                                <p>@UiText.Value(appointment.Reason)</p>
                            </div>
                        </div>
                    </div>

                    <div class="appointment-card-side">
                        <StatusBadge Status="@appointment.Status" />

                        <div class="appointment-card-actions">
                            @if (role == "Owner")
                            {
                                <button class="btn btn-danger btn-sm" @onclick="() => CancelAppointment(appointment.Id)" type="button">Отменить</button>
                            }
                            @if (role == "Veterinarian")
                            {
                                @if (appointment.Status == VetClinic.Shared.Enums.AppointmentStatus.Planned)
                                {
                                    <button class="btn btn-primary btn-sm" @onclick="() => ChangeStatus(appointment.Id, VetClinic.Shared.Enums.AppointmentStatus.Confirmed)" type="button">Подтвердить</button>
                                    <button class="btn btn-secondary btn-sm" @onclick="() => ChangeStatus(appointment.Id, VetClinic.Shared.Enums.AppointmentStatus.Completed)" type="button">Завершить</button>
                                }
                                else if (appointment.Status == VetClinic.Shared.Enums.AppointmentStatus.Confirmed)
                                {
                                    <button class="btn btn-secondary btn-sm" @onclick="() => ChangeStatus(appointment.Id, VetClinic.Shared.Enums.AppointmentStatus.Completed)" type="button">Завершить</button>
                                }
                            }
                        </div>
                    </div>
                </article>
            }
        </div>
    }
</section>

@code {
    private List<VetClinic.Shared.Responses.AppointmentResponse> appointments = [];
    private string role = string.Empty;
    private string message = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        role = await LocalStorageService.GetItemAsync("role") ?? string.Empty;
        await LoadAppointmentsAsync();
    }

    private async Task LoadAppointmentsAsync()
    {
        appointments = (await AppointmentApiService.GetMyAsync())
            .OrderBy(a => a.Status == VetClinic.Shared.Enums.AppointmentStatus.Completed)
            .ThenBy(a => a.StartAt)
            .ToList();
    }

    private void OpenCreatePage()
    {
        Navigation.NavigateTo("/appointments/create");
    }

    private async Task CancelAppointment(int id)
    {
        var result = await AppointmentApiService.DeleteAsync(id);
        message = result ? string.Empty : "Не удалось отменить запись. Попробуйте обновить страницу.";
        await LoadAppointmentsAsync();
    }

    private async Task ChangeStatus(int id, VetClinic.Shared.Enums.AppointmentStatus status)
    {
        var result = await AppointmentApiService.UpdateStatusAsync(id, new VetClinic.Shared.Requests.UpdateAppointmentStatusRequest
        {
            Status = status
        });

        message = result is null ? "Не удалось сохранить данные. Проверьте заполнение формы." : string.Empty;
        await LoadAppointmentsAsync();
    }

}
