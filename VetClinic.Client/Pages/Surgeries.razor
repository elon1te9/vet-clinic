@page "/surgeries"
@inject VetClinic.Client.Services.SurgeryApiService SurgeryApiService
@inject VetClinic.Client.Services.LocalStorageService LocalStorageService

<PageTitle>Операции</PageTitle>

<PageHeader Title="Операции" Description="Планирование и статусы хирургических операций." />

<ErrorMessage Text="@message" />

<section class="section-card">
@if (role == "Veterinarian")
{
    <p><a class="btn btn-primary" href="surgeries/create">Создать операцию</a></p>
}

@if (surgeries.Count == 0)
{
    <EmptyState Title="Операций нет" Message="Операции появятся после создания." />
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>Дата</th>
                <th>Питомец</th>
                <th>Название</th>
                <th>Статус</th>
                <th>Врач</th>
                <th>Ассистент</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var surgery in surgeries)
            {
                <tr>
                    <td>@surgery.ScheduledAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</td>
                    <td>@surgery.PetName</td>
                    <td>@surgery.Title</td>
                    <td><StatusBadge Status="@surgery.Status" /></td>
                    <td>@surgery.VeterinarianFullName</td>
                    <td>@surgery.AssistantFullName</td>
                    <td>
                        @if (role == "Admin" || role == "Veterinarian")
                        {
                            <button class="btn btn-primary btn-sm" @onclick="() => SetStatus(surgery.Id, VetClinic.Shared.Enums.SurgeryStatus.InProgress)" type="button">InProgress</button>
                            <button class="btn btn-secondary btn-sm" @onclick="() => SetStatus(surgery.Id, VetClinic.Shared.Enums.SurgeryStatus.Completed)" type="button">Completed</button>
                            <button class="btn btn-danger btn-sm" @onclick="() => SetStatus(surgery.Id, VetClinic.Shared.Enums.SurgeryStatus.Cancelled)" type="button">Cancelled</button>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
</section>

@code {
    private List<VetClinic.Shared.Responses.SurgeryResponse> surgeries = [];
    private string role = string.Empty;
    private string message = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        role = await LocalStorageService.GetItemAsync("role") ?? string.Empty;
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        surgeries = await SurgeryApiService.GetAllAsync();
    }

    private async Task SetStatus(int id, VetClinic.Shared.Enums.SurgeryStatus status)
    {
        var result = await SurgeryApiService.UpdateStatusAsync(id, status);
        message = result is null ? "Не удалось изменить статус." : "Статус изменён.";

        await LoadAsync();
    }
}
