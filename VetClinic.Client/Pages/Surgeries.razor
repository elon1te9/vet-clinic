@page "/surgeries"
@inject VetClinic.Client.Services.SurgeryApiService SurgeryApiService
@inject VetClinic.Client.Services.LocalStorageService LocalStorageService

<PageTitle>Операции</PageTitle>

<PageHeader Title="Операции" Description="Планирование и статусы хирургических операций.">
    <Actions>
        @if (role == "Veterinarian")
        {
            <a class="btn btn-primary" href="surgeries/create">Создать операцию</a>
        }
    </Actions>
</PageHeader>

<ErrorMessage Text="@message" />

<section class="section-card">
@if (surgeries.Count == 0)
{
    <EmptyState Title="Операции пока не запланированы" Message="Создайте операцию, чтобы контролировать подготовку, ассистента и статус выполнения." />
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>Дата</th>
                <th>Питомец</th>
                <th>Название</th>
                <th>Статус</th>
                <th>Врач</th>
                <th>Ассистент</th>
                <th class="table-actions-cell"></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var surgery in surgeries)
            {
                <tr>
                    <td>@FormatSurgeryDate(surgery.ScheduledAt)</td>
                    <td>@UiText.Value(surgery.PetName)</td>
                    <td>@UiText.Value(surgery.Title)</td>
                    <td><StatusBadge Status="@surgery.Status" /></td>
                    <td>@UiText.Value(surgery.VeterinarianFullName)</td>
                    <td>@UiText.Value(surgery.AssistantFullName)</td>
                    <td class="table-actions-cell">
                        @if (role == "Admin" || role == "Veterinarian")
                        {
                            @if (surgery.Status == VetClinic.Shared.Enums.SurgeryStatus.Planned)
                            {
                                <button class="btn btn-primary btn-sm" @onclick="() => SetStatus(surgery.Id, VetClinic.Shared.Enums.SurgeryStatus.InProgress)" type="button">Начать</button>
                                <button class="btn btn-danger btn-sm" @onclick="() => SetStatus(surgery.Id, VetClinic.Shared.Enums.SurgeryStatus.Cancelled)" type="button">Отменить</button>
                            }
                            else if (surgery.Status == VetClinic.Shared.Enums.SurgeryStatus.InProgress)
                            {
                                <button class="btn btn-secondary btn-sm" @onclick="() => SetStatus(surgery.Id, VetClinic.Shared.Enums.SurgeryStatus.Completed)" type="button">Завершить</button>
                            }
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
</section>

@code {
    private List<VetClinic.Shared.Responses.SurgeryResponse> surgeries = [];
    private string role = string.Empty;
    private string message = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        role = await LocalStorageService.GetItemAsync("role") ?? string.Empty;
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        surgeries = await SurgeryApiService.GetAllAsync();
    }

    private async Task SetStatus(int id, VetClinic.Shared.Enums.SurgeryStatus status)
    {
        var result = await SurgeryApiService.UpdateStatusAsync(id, status);
        message = result is null ? "Не удалось изменить статус." : "Статус изменён.";

        await LoadAsync();
    }

    private static string FormatSurgeryDate(DateTime value)
    {
        return value.ToString("dd.MM.yyyy");
    }
}
