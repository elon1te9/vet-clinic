@page "/login"
@inject VetClinic.Client.Services.AuthService AuthService
@inject NavigationManager Navigation

<PageTitle>Вход</PageTitle>

<div class="auth-page">
    <div class="auth-card">
        <PageHeader Title="Вход" Description="Войдите в аккаунт, чтобы открыть рабочий кабинет." />

        <div>
            <label>Электронная почта</label>
            <input @bind="email" autocomplete="username" />
        </div>

        <div>
            <label>Пароль</label>
            <input type="password" @bind="password" autocomplete="current-password" />
        </div>

        <ErrorMessage Text="@errorMessage" />

        <div class="actions-row">
            <button class="btn btn-primary" @onclick="LoginUser" type="button">Войти</button>
            <a class="btn btn-secondary" href="register">Регистрация</a>
        </div>
    </div>
</div>

@code {
    private string email = string.Empty;
    private string password = string.Empty;
    private string errorMessage = string.Empty;

    private async Task LoginUser()
    {
        if (string.IsNullOrWhiteSpace(email) || string.IsNullOrWhiteSpace(password))
        {
            errorMessage = "Заполните все поля.";
            return;
        }

        errorMessage = string.Empty;

        var result = await AuthService.LoginAsync(new VetClinic.Shared.Requests.LoginRequest
        {
            Email = email,
            Password = password
        });

        if (result is null)
        {
            errorMessage = "Неверная электронная почта или пароль.";
            return;
        }

        Navigation.NavigateTo("/", true);
    }
}
