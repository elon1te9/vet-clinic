@page "/notifications"
@implements IDisposable
@inject VetClinic.Client.Services.NotificationApiService NotificationApiService
@inject VetClinic.Client.Services.SignalRNotificationService SignalRNotificationService

<PageTitle>Уведомления</PageTitle>

<h1>Уведомления</h1>

@if (!string.IsNullOrWhiteSpace(message))
{
    <p>@message</p>
}

@if (notifications.Count > 0)
{
    <button @onclick="MarkAllAsRead" type="button">Прочитать все</button>
}

@if (notifications.Count == 0)
{
    <p>Уведомлений нет.</p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>Дата</th>
                <th>Тип</th>
                <th>Заголовок</th>
                <th>Сообщение</th>
                <th>Прочитано</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var notification in notifications)
            {
                <tr>
                    <td>@notification.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</td>
                    <td>@notification.Type</td>
                    <td>@notification.Title</td>
                    <td>@notification.Message</td>
                    <td><StatusBadge Text="@(notification.IsRead ? "Прочитано" : "Новое")" /></td>
                    <td>
                        @if (!notification.IsRead)
                        {
                            <button class="btn-sm" @onclick="() => MarkAsRead(notification.Id)" type="button">Прочитать</button>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<VetClinic.Shared.Responses.NotificationResponse> notifications = [];
    private string message = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        SignalRNotificationService.NotificationReceived += OnNotificationReceived;
        await SignalRNotificationService.StartAsync();
        await LoadNotificationsAsync();
    }

    private async Task LoadNotificationsAsync()
    {
        notifications = await NotificationApiService.GetMyAsync();
    }

    private async Task MarkAsRead(int id)
    {
        var result = await NotificationApiService.MarkAsReadAsync(id);
        message = result ? "Уведомление прочитано." : "Не удалось прочитать уведомление.";

        await LoadNotificationsAsync();
    }

    private async Task MarkAllAsRead()
    {
        var result = await NotificationApiService.MarkAllAsReadAsync();
        message = result ? "Все уведомления прочитаны." : "Не удалось прочитать уведомления.";

        await LoadNotificationsAsync();
    }

    private void OnNotificationReceived(VetClinic.Shared.Responses.NotificationResponse notification)
    {
        if (!notifications.Any(n => n.Id == notification.Id))
        {
            notifications.Insert(0, notification);
            _ = InvokeAsync(StateHasChanged);
        }
    }

    public void Dispose()
    {
        SignalRNotificationService.NotificationReceived -= OnNotificationReceived;
    }
}
