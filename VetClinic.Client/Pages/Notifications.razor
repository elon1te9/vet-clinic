@page "/notifications"
@implements IDisposable
@inject VetClinic.Client.Services.NotificationApiService NotificationApiService
@inject VetClinic.Client.Services.SignalRNotificationService SignalRNotificationService

<PageTitle>Уведомления</PageTitle>

<PageHeader Title="Уведомления" Description="Системные уведомления текущего пользователя." />

<ErrorMessage Text="@message" />

<section class="section-card">
@if (notifications.Count > 0)
{
    <button class="btn btn-primary" @onclick="MarkAllAsRead" type="button">Прочитать все</button>
}

@if (notifications.Count == 0)
{
    <EmptyState Title="Новых уведомлений нет" Message="Когда появятся записи, вакцинации, складские события или счета, уведомления будут здесь." />
}
else
{
    <table class="table notifications-table">
        <thead>
            <tr>
                <th>Дата</th>
                <th>Заголовок</th>
                <th>Сообщение</th>
                <th>Статус</th>
                <th class="table-actions-cell"></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var notification in notifications)
            {
                <tr>
                    <td>@UiText.Date(notification.CreatedAt)</td>
                    <td>@UiText.Value(notification.Title)</td>
                    <td>@UiText.Value(FormatNotificationMessage(notification.Message))</td>
                    <td>
                        <span class="notification-status @(notification.IsRead ? "notification-status-read" : "notification-status-new")">
                            @(notification.IsRead ? "Прочитано" : "Новое")
                        </span>
                    </td>
                    <td class="table-actions-cell">
                        @if (!notification.IsRead)
                        {
                            <button class="btn btn-secondary btn-sm" @onclick="() => MarkAsRead(notification.Id)" type="button">Прочитать</button>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
</section>

@code {
    private List<VetClinic.Shared.Responses.NotificationResponse> notifications = [];
    private string message = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        SignalRNotificationService.NotificationReceived += OnNotificationReceived;
        await SignalRNotificationService.StartAsync();
        await LoadNotificationsAsync();
    }

    private async Task LoadNotificationsAsync()
    {
        notifications = await NotificationApiService.GetMyAsync();
        NotificationApiService.NotifyNotificationsChanged();
    }

    private async Task MarkAsRead(int id)
    {
        var result = await NotificationApiService.MarkAsReadAsync(id);
        message = result ? string.Empty : "Не удалось прочитать уведомление.";

        await LoadNotificationsAsync();
    }

    private async Task MarkAllAsRead()
    {
        var result = await NotificationApiService.MarkAllAsReadAsync();
        message = result ? string.Empty : "Не удалось прочитать уведомления.";

        await LoadNotificationsAsync();
    }

    private static string? FormatNotificationMessage(string? text)
    {
        if (string.IsNullOrWhiteSpace(text))
        {
            return text;
        }

        return text
            .Replace(": Planned.", ": Запланировано.")
            .Replace(": Confirmed.", ": Подтверждено.")
            .Replace(": Completed.", ": Завершено.")
            .Replace(": Cancelled.", ": Отменено.");
    }

    private void OnNotificationReceived(VetClinic.Shared.Responses.NotificationResponse notification)
    {
        if (!notifications.Any(n => n.Id == notification.Id))
        {
            notifications.Insert(0, notification);
            NotificationApiService.NotifyNotificationsChanged();
            _ = InvokeAsync(StateHasChanged);
        }
    }

    public void Dispose()
    {
        SignalRNotificationService.NotificationReceived -= OnNotificationReceived;
    }
}
